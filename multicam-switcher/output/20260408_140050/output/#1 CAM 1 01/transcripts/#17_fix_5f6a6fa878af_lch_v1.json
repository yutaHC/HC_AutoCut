[
  {
    "start": 0.0,
    "end": 29.98,
    "text": "ご視聴ありがとうございました",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 30.0,
    "end": 59.98,
    "text": "次回予告",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 60.0,
    "end": 63.66,
    "text": "はいみなさんこんにちはMCを務めますレコの内田総一郎です",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 63.66,
    "end": 66.9,
    "text": "週刊ヘアキャンプ今週のゲストをご紹介します",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 66.9,
    "end": 71.14,
    "text": "一人目のゲストマジコ上原純一郎さんですよろしくお願いします",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 71.14,
    "end": 73.74,
    "text": "マジコ上原純一郎です",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 73.74,
    "end": 78.5,
    "text": "そうですね私はなんかあんまりマネーリテラシーって書いて",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 78.5,
    "end": 81.18,
    "text": "そういったイメージないんですけれども",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 81.18,
    "end": 86.58,
    "text": "やはりこういったお金の知識やっぱりそういったのも興味ありますので",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 86.58,
    "end": 89.3,
    "text": "今日は勉強したいと思いますのでよろしくお願いします",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 89.3,
    "end": 89.98,
    "text": "お願いします",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 89.98,
    "end": 93.26,
    "text": "そして二人目のゲストはファイブスター佐久間雅之さんです",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 93.26,
    "end": 95.02,
    "text": "ファイブスターグループ代表の佐久間です",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 95.02,
    "end": 96.82,
    "text": "今日はよろしくお願いします",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 96.82,
    "end": 102.62,
    "text": "資産形成とか自己投資に関しては20代半ばぐらいから意識してやってきたんですけど",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 102.62,
    "end": 107.84,
    "text": "いろいろと経験してきているのでたくさん今日はお話できたら嬉しいなと思ってます",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 107.84,
    "end": 108.88,
    "text": "よろしくお願いします",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 108.88,
    "end": 109.56,
    "text": "よろしくお願いします",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 109.56,
    "end": 113.38,
    "text": "そして三人目のゲストはエイト渡辺義明さんです",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 113.38,
    "end": 115.4,
    "text": "エイトの渡辺ですよろしくお願いします",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 115.4,
    "end": 119.64,
    "text": "今はメイン授業で投資進捗の教育というものをやってまして",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 119.64,
    "end": 119.96,
    "text": "投資進捗の教育というものをやってまして",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 119.96,
    "end": 123.48,
    "text": "今日は皆さんにためになる情報をお届けできればなと思ってます",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 123.48,
    "end": 124.2,
    "text": "よろしくお願いします",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 124.2,
    "end": 129.3,
    "text": "そして四人目のゲストは愛東京鎌方亮さんです",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 129.3,
    "end": 132.22,
    "text": "元愛東京代表の鎌方亮です",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 132.22,
    "end": 136.08,
    "text": "今代表を降りて旅人をやってるんですけども",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 136.08,
    "end": 138.4,
    "text": "この撮影のために緊急帰国してまいりました",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 138.4,
    "end": 143.06,
    "text": "あまり資産付与のこととか僕よく分かってないんですけど",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 143.06,
    "end": 146.86,
    "text": "視聴者の方と同じ目線に立っていろんな人に質問していきたいなと",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 146.86,
    "end": 149.94,
    "text": "なんでヴィンテージそんなに買ってるんですかみたいなのを聞いていきたいと思うので",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 149.96,
    "end": 150.66,
    "text": "よろしくお願いします",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 150.66,
    "end": 154.64,
    "text": "今回はこちらの4名の皆さんとお送りします",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 154.64,
    "end": 155.74,
    "text": "よろしくお願いします",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 155.74,
    "end": 160.8,
    "text": "早速最初のテーマはこちら",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 160.8,
    "end": 165.28,
    "text": "あなたはどっち稼ぐ美容師残す美容師",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 165.28,
    "end": 170.88,
    "text": "ということで今回は美容室経営で大活躍されている4名の皆様にお越しいただいております",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 170.88,
    "end": 177.22,
    "text": "まずは自己紹介兼ねて皆さんの資産運用の考え方についてお伺いしたいと思うんですが",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 177.22,
    "end": 178.96,
    "text": "まずはじゅんさんからお願いします",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 179.96,
    "end": 183.78,
    "text": "どっちかっていうと稼げない系美容師だったんで",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 183.78,
    "end": 192.1,
    "text": "それを武器にですね仲間というかスタッフに稼がせる系サロンを運営し始めたところ",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 192.1,
    "end": 198.74,
    "text": "うまくいったっていう形はある程度言えるんじゃないかなと思っています",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 198.74,
    "end": 206.06,
    "text": "じゅんさんといえば結構ねいろんな人の教育に携わっていろんな人を成功したでおなじみの方だと思う",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 206.06,
    "end": 207.54,
    "text": "そう言っていただけるとありがたい",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 207.54,
    "end": 209.94,
    "text": "だいたいじゅんさんと関わる人は全員お金持ちで",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 209.96,
    "end": 210.7,
    "text": "お金持ちになってるっていう",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 210.7,
    "end": 211.98,
    "text": "確かに",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 211.98,
    "end": 213.62,
    "text": "なんで僕もお金持ちになってないでしょ",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 213.62,
    "end": 215.2,
    "text": "関わりたいんです",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 215.2,
    "end": 221.12,
    "text": "でもなんか分かりますよね成功する人って",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 221.12,
    "end": 224.08,
    "text": "やっぱり人と人が集まってくるというか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 224.08,
    "end": 228.32,
    "text": "人と人が出会ってするお仕事だから美容師って",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 228.32,
    "end": 232.06,
    "text": "なんかこう人に愛されるとか人に良くして差し上げるっていうか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 232.06,
    "end": 237.84,
    "text": "そういうことができる人がやはり成功してるのかなっていう印象ですね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 237.84,
    "end": 239.94,
    "text": "そうくん我々の時代ってやっぱりデザインの人が多くて",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 239.96,
    "end": 243.58,
    "text": "デザインとか技術とかより多く求められたじゃないですか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 243.58,
    "end": 248.34,
    "text": "そういったことってなんかすごいなんか文化的だしめちゃくちゃいいけど",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 248.34,
    "end": 251.34,
    "text": "じゃあそれがそういうなんて人に伝わるかとか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 251.34,
    "end": 253.84,
    "text": "なんかこうね資産それも資産運用じゃないですか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 253.84,
    "end": 258.8,
    "text": "技術とか思いとか文化みたいなものも運用できてるかっていうと",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 258.8,
    "end": 263.08,
    "text": "その辺が難しくてやっぱりこう衰退があるのかなっていう印象がありますね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 263.08,
    "end": 268.72,
    "text": "我々の時代はなんかそういう株やりましょうみたいな時代じゃなかったですもんね美容師さんがね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 268.72,
    "end": 269.58,
    "text": "そうそう",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 269.96,
    "end": 273.18,
    "text": "なんか株とかコインやってるやつダサい",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 273.18,
    "end": 277.0,
    "text": "ダサいおいいっすねいいぶっこみが",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 277.0,
    "end": 280.5,
    "text": "なんかマネーリテラシー語れた方がかっこいいんですよ",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 280.5,
    "end": 283.48,
    "text": "語ってる風なのももはやダサい",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 283.48,
    "end": 286.54,
    "text": "もうそんなチャットGPで聞いたらいいじゃん",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 286.54,
    "end": 287.28,
    "text": "なるほどなるほど",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 287.28,
    "end": 288.74,
    "text": "なんかそれでもう",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 288.74,
    "end": 289.48,
    "text": "いかがわしい感じ",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 289.48,
    "end": 290.96,
    "text": "そうそうそうそうそうそう",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 290.96,
    "end": 294.92,
    "text": "まあいいんですけどそれもまたね楽しみだと思いますし",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 294.92,
    "end": 298.62,
    "text": "やっぱり経済回してた方がいいと思うんですけど",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 298.62,
    "end": 298.96,
    "text": "あの",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 299.96,
    "end": 304.82,
    "text": "もうすごい頭悪いから友達が儲かるよとか言ってコインやってすごい増えたとか言ったって",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 304.82,
    "end": 308.9,
    "text": "結局お金にするときにね雑所得だから50%取られるわけですよ",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 308.9,
    "end": 314.0,
    "text": "全然その時間と没入してるもう変な趣味みたいな感じじゃないですか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 314.0,
    "end": 318.62,
    "text": "大枠で言うとじゃあ資産運用にはいまだにちょっと反対派というか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 318.62,
    "end": 321.68,
    "text": "自己投資にちゃんと金使った方がいいよって派ってことで",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 321.68,
    "end": 323.48,
    "text": "もう完全にそうですね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 323.48,
    "end": 329.72,
    "text": "美容師さんはもう自分にね自分が商品ですから自分にやっぱりお金をかけて欲しい",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 329.72,
    "end": 334.92,
    "text": "だけど僕運用とかっていうと角度によるかもしれないけど",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 334.92,
    "end": 336.96,
    "text": "やっぱり積み立てであるとか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 336.96,
    "end": 339.86,
    "text": "あの我々の頃のあの積み立てって",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 339.86,
    "end": 342.18,
    "text": "そうか勝手に給料から転引されてて",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 342.18,
    "end": 344.72,
    "text": "なんかただただなんか貯金させられてて",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 344.72,
    "end": 347.42,
    "text": "なんか気が付いたらすごい高いハサミ買わされたりとか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 347.42,
    "end": 353.12,
    "text": "だけど今の積み立てって",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 353.12,
    "end": 355.62,
    "text": "あの足し算じゃなくて掛け算だったりするんですよね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 355.62,
    "end": 359.56,
    "text": "対象金向けの積み立てはそういう運用みたいなことはもう",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 359.72,
    "end": 365.56,
    "text": "本当に1年生の頃から5千円でも1万円でも掛けておくとね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 365.56,
    "end": 370.22,
    "text": "これとんでもない20年30年働いた時にとんでもない金額になりますから",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 370.22,
    "end": 372.96,
    "text": "そういったことは進めた方がいいと思うし",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 372.96,
    "end": 377.02,
    "text": "その最前線にいるのが佐久間さんということで",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 377.02,
    "end": 380.96,
    "text": "僕はあのヘアキャンプさんでマネーリテラシアの教科書っていうね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 380.96,
    "end": 382.02,
    "text": "テーマでやらせられてるんで",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 382.02,
    "end": 385.22,
    "text": "じゅんさんのお考えと少しね違うところにいるのかもしれないですけど",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 385.22,
    "end": 386.38,
    "text": "いやいやそんなことないです",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 386.38,
    "end": 389.72,
    "text": "ただ僕25歳の時のリクルートに入った時はね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 389.72,
    "end": 392.72,
    "text": "一番最初のお客様が上原純一郎さんで",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 392.72,
    "end": 393.72,
    "text": "そうなんですね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 393.72,
    "end": 395.72,
    "text": "一応ホットペッパーの担当です",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 395.72,
    "end": 398.72,
    "text": "もう20年ぐらいの付き合いなんですね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 398.72,
    "end": 401.72,
    "text": "だからああだこうだ言いつつも",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 401.72,
    "end": 405.72,
    "text": "でも下北の市サロンのオーナーだったのに",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 405.72,
    "end": 408.72,
    "text": "今やもう業界を代表するオーナーになって",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 408.72,
    "end": 410.72,
    "text": "なんかいじられてるいじられてる",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 410.72,
    "end": 415.72,
    "text": "だからこう言いながらも本当はやってんじゃねえなって思いますし",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 415.72,
    "end": 416.72,
    "text": "確かに確かに",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 416.72,
    "end": 418.72,
    "text": "立ち回り的にやってるなって思いますね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 418.72,
    "end": 419.72,
    "text": "なるほど",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 419.72,
    "end": 422.72,
    "text": "古い付き合いなんで僕のこともよく知ってるし",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 422.72,
    "end": 423.72,
    "text": "じゅんさんのこともよく知ってるんですけど",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 423.72,
    "end": 428.72,
    "text": "自分はやっぱり稼ぐ美容師ってところをまず推奨したいなと思うんですよね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 428.72,
    "end": 433.72,
    "text": "ただ稼ぐって言葉をもうちょっと語彙力持って伝えたいなと思っていて",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 433.72,
    "end": 440.72,
    "text": "単に稼ぐって言うと休日減らして働くとか時間を長く働くとか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 440.72,
    "end": 442.72,
    "text": "それもそれでやるべき時はあると思うんですけど",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 442.72,
    "end": 447.72,
    "text": "それだけじゃなくてちゃんと自己投資を伴った自分らしい稼ぎ方とか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 447.72,
    "end": 449.72,
    "text": "自分らしい個性を持った",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 449.72,
    "end": 454.72,
    "text": "美容師になってより使命を獲得して単価を上げていくっていうのが",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 454.72,
    "end": 457.72,
    "text": "僕は適切な稼い方なんじゃないかなと思うんですよ",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 457.72,
    "end": 458.72,
    "text": "楽しみながらね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 458.72,
    "end": 459.72,
    "text": "そういった意味で僕はね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 459.72,
    "end": 463.72,
    "text": "いろんなヴィンテージとか時計とかいろんなものをやりながらも",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 463.72,
    "end": 465.72,
    "text": "それは自分の自己投資になってて",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 465.72,
    "end": 467.72,
    "text": "佐久間さんらしい",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 467.72,
    "end": 470.72,
    "text": "でも結局それによっていろんな人がたくさん集まってきて",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 470.72,
    "end": 472.72,
    "text": "佐久間さんの元で働きたいっていうのになっていて",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 472.72,
    "end": 475.72,
    "text": "それは結果今の会社の成長にもつながってるんで",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 475.72,
    "end": 478.72,
    "text": "人が集まるような稼い方になってきてるのかなと思うんですよね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 478.72,
    "end": 484.72,
    "text": "なので僕は本当に株式投資から投資信託から債券投資",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 484.72,
    "end": 486.72,
    "text": "不動産、仮想通貨とか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 486.72,
    "end": 489.72,
    "text": "あと現物投資いろいろやってきてるんで",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 489.72,
    "end": 491.72,
    "text": "だからこそ粋も甘えも分かってますし",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 491.72,
    "end": 494.72,
    "text": "たくさん失敗もしてきてるからこそ",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 494.72,
    "end": 497.72,
    "text": "人に教えられる立場に今は来れてるのかなと思ってます",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 497.72,
    "end": 498.72,
    "text": "それも含めてね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 498.72,
    "end": 500.72,
    "text": "まずは自分作りっていうところに",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 500.72,
    "end": 503.72,
    "text": "結構全力で投資してきたかななんて思いますね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 503.72,
    "end": 504.72,
    "text": "なるほど",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 504.72,
    "end": 507.72,
    "text": "つまり佐久間さんはそういう美容師さんを増やして",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 507.72,
    "end": 508.72,
    "text": "ちゃんとお金を出して",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 508.72,
    "end": 510.72,
    "text": "自分に知識持ってやって",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 510.72,
    "end": 513.72,
    "text": "元手がある人はもっと稼いでいこうよっていうのを",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 513.72,
    "end": 515.72,
    "text": "よく部屋見込みでやってるっていう",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 515.72,
    "end": 518.72,
    "text": "元手がある人はもっと賢く使って",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 518.72,
    "end": 521.72,
    "text": "多分影響力のある立場にいらっしゃるでしょうから",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 521.72,
    "end": 522.72,
    "text": "そうじゃない人たちは",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 522.72,
    "end": 524.72,
    "text": "これから自分がそういう立場になる側に",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 524.72,
    "end": 526.72,
    "text": "いってほしいなと思いますね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 526.72,
    "end": 529.72,
    "text": "バッドホップみたいな感じでしょ",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 529.72,
    "end": 531.72,
    "text": "俺みたいにやれよみたいな",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 531.72,
    "end": 533.72,
    "text": "そうするとファミリーいっぱい増えますからね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 533.72,
    "end": 536.72,
    "text": "ちょっともうこの後すぐセミナー見ますね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 536.72,
    "end": 537.72,
    "text": "ありがとうございます",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 537.72,
    "end": 538.72,
    "text": "では渡辺さんの方",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 538.72,
    "end": 543.72,
    "text": "僕も20代めちゃくちゃバリバリ美容師もやってたので",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 543.72,
    "end": 548.72,
    "text": "結構な大型店舗で働いてたっていうので",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 548.72,
    "end": 550.72,
    "text": "給料もめちゃくちゃ安かったんで",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 550.72,
    "end": 554.72,
    "text": "とりあえず投資っていうものが皆無というか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 554.72,
    "end": 556.72,
    "text": "全く違うところにあって",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 556.72,
    "end": 559.72,
    "text": "とりあえず技術を習得していって",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 559.72,
    "end": 562.72,
    "text": "売り上げを上げていくっていうところからやっていって",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 562.72,
    "end": 566.72,
    "text": "やっぱりある程度売り上げが上がってくると",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 566.72,
    "end": 568.72,
    "text": "ちょっとお金ってやらしい話",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 568.72,
    "end": 570.72,
    "text": "ちょっと余ってきたりもするじゃないですか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 570.72,
    "end": 573.72,
    "text": "っていうので僕は20代後半ぐらいから",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 573.72,
    "end": 577.72,
    "text": "投資って言われてるものを独学で全部勉強したり",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 577.72,
    "end": 580.72,
    "text": "あとは美容師って結構お客様だったりとか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 580.72,
    "end": 582.72,
    "text": "いろんな方々結構来るんで",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 582.72,
    "end": 586.72,
    "text": "悪い人が来てこういったものがあるよみたいなんで",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 586.72,
    "end": 587.72,
    "text": "いい感じに騙されたり",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 587.72,
    "end": 588.72,
    "text": "そうなんです",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 588.72,
    "end": 591.72,
    "text": "詐欺みたいなもので",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 591.72,
    "end": 594.72,
    "text": "例えば不動産がこういったものがあるよって言って",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 594.72,
    "end": 596.72,
    "text": "そういうのもじゃあ",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 596.72,
    "end": 598.72,
    "text": "ホイホイついて行って買ってみたり",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 598.72,
    "end": 602.72,
    "text": "それが実は何もなかったよみたいなところだったりとか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 602.72,
    "end": 605.72,
    "text": "実際も不動産投資してローンを組まされたけど",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 605.72,
    "end": 608.72,
    "text": "そのローンの組み方がなんだろう",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 608.72,
    "end": 609.72,
    "text": "悪いローンの組み方",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 609.72,
    "end": 612.72,
    "text": "いわゆる投資用ローンではなく",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 612.72,
    "end": 614.72,
    "text": "住宅ローンで組まされてたりとか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 614.72,
    "end": 617.72,
    "text": "そういったものも含めて",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 617.72,
    "end": 622.72,
    "text": "騙されない美容師さんがいっぱいできればいいなっていうところで",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 622.72,
    "end": 625.72,
    "text": "僕できることならこういうことが好きだから",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 625.72,
    "end": 627.72,
    "text": "本当に教えることも結構好きだったんで",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 627.72,
    "end": 630.72,
    "text": "教育として僕はやっていこうかなと",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 630.72,
    "end": 633.72,
    "text": "だから騙されない美容師で",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 633.72,
    "end": 637.72,
    "text": "めっちゃ稼ぐっていうのではちょっとなく",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 637.72,
    "end": 639.72,
    "text": "安心して生活できる",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 639.72,
    "end": 642.72,
    "text": "美容師人生も安心してできるような",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 642.72,
    "end": 645.72,
    "text": "お金の働かし方みたいなところを",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 645.72,
    "end": 648.72,
    "text": "皆さんにお伝えできればなと思って",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 648.72,
    "end": 650.72,
    "text": "同じようにセミナーもやられてるわけですもんね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 650.72,
    "end": 652.72,
    "text": "そうですね僕もヘアキャンプさんで",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 652.72,
    "end": 655.72,
    "text": "2回ぐらいはやらせていただいて",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 655.72,
    "end": 657.72,
    "text": "すぐ見ます",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 657.72,
    "end": 660.72,
    "text": "向かってくるとき僕見てましたから",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 660.72,
    "end": 661.72,
    "text": "見ながら来ました",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 661.72,
    "end": 663.72,
    "text": "エレベーターの前で言われたんですね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 663.72,
    "end": 665.72,
    "text": "濱中君なんかは",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 665.72,
    "end": 668.72,
    "text": "あんまりねそういう投資みたいなのしてません",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 668.72,
    "end": 669.72,
    "text": "みたいな話もしてたんですけど",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 669.72,
    "end": 671.72,
    "text": "めちゃくちゃやってますよ",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 671.72,
    "end": 673.72,
    "text": "資産運用管理会社持ってますから自分",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 673.72,
    "end": 676.72,
    "text": "僕はやっぱり自分が欲しかったものを",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 676.72,
    "end": 678.72,
    "text": "運用として回せるように",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 678.72,
    "end": 681.72,
    "text": "フェラーリ買ったりロレックス買ったり",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 681.72,
    "end": 683.72,
    "text": "車時計買ったりとか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 683.72,
    "end": 685.72,
    "text": "買ったりとかはいっぱいして",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 685.72,
    "end": 687.72,
    "text": "今はもうそうなんか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 687.72,
    "end": 689.72,
    "text": "これぶっちゃけ自分が欲しかっただけじゃねって思って",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 689.72,
    "end": 691.72,
    "text": "全部売っちゃったんですけど",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 691.72,
    "end": 692.72,
    "text": "もういらねえと思って",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 692.72,
    "end": 695.72,
    "text": "今は自分に投資しように全突破してるんですけど今は",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 695.72,
    "end": 699.72,
    "text": "思ったんですけど稼がないと残せなくないとか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 699.72,
    "end": 701.72,
    "text": "本当にそう",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 701.72,
    "end": 703.72,
    "text": "なんで稼ぐ美容師か残す美容師かやってたら",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 703.72,
    "end": 705.72,
    "text": "まず稼げよみたいなのもある",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 705.72,
    "end": 707.72,
    "text": "それができるようになってから",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 707.72,
    "end": 709.72,
    "text": "初めて残すことを考えた方がいいんじゃないかな",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 709.72,
    "end": 711.72,
    "text": "それはおっしゃる通り",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 711.72,
    "end": 712.72,
    "text": "美容師として稼ぐ",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 712.72,
    "end": 714.72,
    "text": "シンプルに説教モードになっちゃってるから",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 715.72,
    "end": 717.72,
    "text": "言うてもヘアキャンミング見てる方は",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 717.72,
    "end": 720.72,
    "text": "まだまだ売れっ子じゃない人もいらっしゃるわけで",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 720.72,
    "end": 722.72,
    "text": "その中でもなけなしのお金を",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 722.72,
    "end": 724.72,
    "text": "どういうふうにちょっとでも",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 724.72,
    "end": 726.72,
    "text": "増やしていけるのかなっていうのも",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 726.72,
    "end": 728.72,
    "text": "ちょっと聞きたいわけですよね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 728.72,
    "end": 731.72,
    "text": "リアルに皆さんの20代だった時っていうのは",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 731.72,
    "end": 735.72,
    "text": "一番どういうふうなお給料の使い方してたんですかまず",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 735.72,
    "end": 738.72,
    "text": "いやだって我々の時はもう",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 738.72,
    "end": 741.72,
    "text": "まともな賃金もらってないですからね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 741.72,
    "end": 743.72,
    "text": "そうですね十何数万の",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 743.72,
    "end": 744.72,
    "text": "そう",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 745.72,
    "end": 750.72,
    "text": "例えば夜クラブで遊びに行って",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 750.72,
    "end": 751.72,
    "text": "代わりの電車値",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 751.72,
    "end": 752.72,
    "text": "タクシーなんか持ってないし",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 752.72,
    "end": 753.72,
    "text": "代わりの電車値ないし",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 753.72,
    "end": 754.72,
    "text": "片道切ってね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 754.72,
    "end": 755.72,
    "text": "だからまずマイナスでしたよね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 755.72,
    "end": 756.72,
    "text": "そうマイナスですよ気持ち",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 756.72,
    "end": 757.72,
    "text": "ずーっとあの",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 757.72,
    "end": 758.72,
    "text": "課金",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 758.72,
    "end": 761.72,
    "text": "そうそう無理くんに変わってましたね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 761.72,
    "end": 762.72,
    "text": "まずマイナス",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 762.72,
    "end": 765.72,
    "text": "いかに仮で起こすかっていう知恵ばかりを",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 765.72,
    "end": 766.72,
    "text": "それはあれですか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 766.72,
    "end": 769.72,
    "text": "その無駄金として本当に使ってたのか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 769.72,
    "end": 773.72,
    "text": "自分の経験として結構意識的に使ってたのかというとどうですか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 773.72,
    "end": 775.72,
    "text": "だからそんなに真面目にですよ",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 775.72,
    "end": 778.72,
    "text": "自分に投資なんて言えるもんじゃないですけど",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 778.72,
    "end": 780.72,
    "text": "やっぱり美容師たるものじゃないですけど",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 780.72,
    "end": 782.72,
    "text": "やっぱり寝る暇惜しいんで",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 782.72,
    "end": 785.72,
    "text": "自分のお金を落としてお洋服買ったりとか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 785.72,
    "end": 788.72,
    "text": "いろんな盛り場に行ってみたりとか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 788.72,
    "end": 791.72,
    "text": "それはある種自己投資ですよね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 791.72,
    "end": 793.72,
    "text": "佐久間さんなんかかなり意識的に",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 793.72,
    "end": 794.72,
    "text": "そうですね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 794.72,
    "end": 797.72,
    "text": "ただ僕もお恥ずかしい話で",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 797.72,
    "end": 801.72,
    "text": "大学時代はパチソロにギャンブルにめちゃめちゃ詰まってしまって",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 801.72,
    "end": 802.72,
    "text": "パチンカスだったんだ",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 802.72,
    "end": 804.72,
    "text": "パチンカスオブパシンカスだった",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 805.72,
    "end": 809.72,
    "text": "今でこそこういう立場になってますけど",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 809.72,
    "end": 812.72,
    "text": "大学4年間で小学金MAXまで借りて",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 812.72,
    "end": 815.72,
    "text": "卒業時に600万の借金を背負うところが始まって",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 815.72,
    "end": 817.72,
    "text": "初任給めちゃめちゃ低くて",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 817.72,
    "end": 819.72,
    "text": "もう人よりもマイナスの状況で",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 819.72,
    "end": 821.72,
    "text": "まだ小学金一応返してるんですけど",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 821.72,
    "end": 823.72,
    "text": "月3万円も払ってたんですよ",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 823.72,
    "end": 825.72,
    "text": "だからそういうお金がない中で",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 825.72,
    "end": 827.72,
    "text": "じゃあどうやって戦わなきゃいけないかって",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 827.72,
    "end": 828.72,
    "text": "超不利じゃないですか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 828.72,
    "end": 830.72,
    "text": "そうすると順さんが言われたように",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 830.72,
    "end": 833.72,
    "text": "自己投資で寝る間惜しんで仕事するとか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 833.72,
    "end": 834.72,
    "text": "寝る間惜しんで誰かのために頑張っていくとかそういうのがあるんですよ",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 835.72,
    "end": 837.72,
    "text": "頑張るみたいなことを社会人になってから",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 837.72,
    "end": 840.72,
    "text": "死ぬ気でやったっていうのはあったなと思うんですよね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 840.72,
    "end": 842.72,
    "text": "やっぱり一回底辺になってから始めて",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 842.72,
    "end": 845.72,
    "text": "お金ちゃんとしようみたいな感じになったんですか",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 845.72,
    "end": 846.72,
    "text": "そうですね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 846.72,
    "end": 848.72,
    "text": "みんな何だかんだ僕のことを捻ってくれてるのは",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 848.72,
    "end": 850.72,
    "text": "やっぱりそういうクソみたいな佐久間がいるっていう",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 850.72,
    "end": 856.72,
    "text": "どっかで見下してる僕のことを持ってくれてるから",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 856.72,
    "end": 858.72,
    "text": "いいわけだと思うんですよ",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 858.72,
    "end": 861.72,
    "text": "もう20年ぐらい前の話だけど",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 861.72,
    "end": 863.72,
    "text": "あの頃から野心はあったよ",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 863.72,
    "end": 865.72,
    "text": "金持ちになるって言ってたんですよ",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 865.72,
    "end": 866.72,
    "text": "金持ちになる",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 866.72,
    "end": 867.72,
    "text": "なりたいって言ってた",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 867.72,
    "end": 868.72,
    "text": "言ってた",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 868.72,
    "end": 869.72,
    "text": "ハングリーでした",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 869.72,
    "end": 871.72,
    "text": "川田君なんか今オキスでしたっけ",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 871.72,
    "end": 872.72,
    "text": "僕今29です",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 872.72,
    "end": 873.72,
    "text": "30です",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 873.72,
    "end": 876.72,
    "text": "だから独立してもう数年経つと思うんですけど",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 876.72,
    "end": 879.72,
    "text": "その当時からやっぱりやったるぞ感",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 879.72,
    "end": 881.72,
    "text": "もう絶対ぶち抜けてやるぞみたいな",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 881.72,
    "end": 883.72,
    "text": "野心の塊みたいな",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 883.72,
    "end": 884.72,
    "text": "まあもうそうなんですけど",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 884.72,
    "end": 887.72,
    "text": "そういう意味でやっぱりお金に対する執着っていうのも",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 887.72,
    "end": 888.72,
    "text": "そこそこ前からあった",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 888.72,
    "end": 892.72,
    "text": "めっちゃ僕家庭がそもそもあまり裕福じゃなかったので",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 892.72,
    "end": 895.72,
    "text": "絶対に稼いでやるぞみたいなのはもう本当に",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 895.72,
    "end": 897.72,
    "text": "それでそのために東京来たみたいな",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 897.72,
    "end": 900.72,
    "text": "ありとあらゆる仏欲はすべて達成して",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 900.72,
    "end": 903.72,
    "text": "ありとあらゆる仏欲はもう達成したような気がします",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 903.72,
    "end": 905.72,
    "text": "達成して今旅人になって",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 905.72,
    "end": 906.72,
    "text": "早いですね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 906.72,
    "end": 908.72,
    "text": "気持ちがいいな",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 908.72,
    "end": 909.72,
    "text": "健在モードにね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 909.72,
    "end": 910.72,
    "text": "健在モードになって",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 910.72,
    "end": 913.72,
    "text": "なぜか今海外に飛び回っちゃってるみたいな",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 913.72,
    "end": 915.72,
    "text": "でも今究極の自己投資しますからね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 915.72,
    "end": 920.72,
    "text": "英語を学ぶために留学自らしてます",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 920.72,
    "end": 923.72,
    "text": "ホームベースを海外でエアビー借りてぐるぐる回って",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 923.72,
    "end": 924.72,
    "text": "それが自己投資で",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 924.72,
    "end": 927.72,
    "text": "英語が喋るようになったらやっぱりマーケットめっちゃ広がるんで",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 927.72,
    "end": 931.72,
    "text": "医療以外もやっぱいろいろな事業が今やってるのいっぱいあるんで",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 931.72,
    "end": 933.72,
    "text": "そうなるとやっぱ海外行った方がマーケットでかいなと思って",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 933.72,
    "end": 935.72,
    "text": "できるようになろうと思って",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 935.72,
    "end": 937.72,
    "text": "それもいわゆる投資ですもんね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 937.72,
    "end": 938.72,
    "text": "まあまあそうですよね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 938.72,
    "end": 942.72,
    "text": "渡辺さんもちなみに底辺は一回",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 942.72,
    "end": 943.72,
    "text": "もちろんもちろん",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 943.72,
    "end": 945.72,
    "text": "僕は○○のカードを",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 945.72,
    "end": 947.72,
    "text": "○○のカードを",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 947.72,
    "end": 950.72,
    "text": "擦るだけ擦りましたね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 950.72,
    "end": 953.72,
    "text": "あれを返すのが本当に大変でした",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 953.72,
    "end": 957.72,
    "text": "使いすぎて上の塗装が赤からグレーになるぐらい",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 957.72,
    "end": 958.72,
    "text": "もちろんリボ払いで",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 958.72,
    "end": 959.72,
    "text": "もちろんもちろん",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 959.72,
    "end": 960.72,
    "text": "リボが減らないんですよ",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 960.72,
    "end": 961.72,
    "text": "全然減らない",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 961.72,
    "end": 963.72,
    "text": "あれ恐ろしいシステムですよね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 963.72,
    "end": 966.72,
    "text": "でも新しいレコードとか見つけちゃったら買うでしょ",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 966.72,
    "end": 967.72,
    "text": "もちろんそうです",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 967.72,
    "end": 969.72,
    "text": "金ないのに買うんだよね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 969.72,
    "end": 971.72,
    "text": "銀行だと思ってました",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 971.72,
    "end": 975.72,
    "text": "本当に借りすぎたら返せないんだっていうところを知ったので",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 975.72,
    "end": 979.72,
    "text": "じゃあちょっとちゃんと働かせないといけないなっていうのが",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 979.72,
    "end": 980.72,
    "text": "始まりだったかもしれない",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 980.72,
    "end": 983.72,
    "text": "皆さん共通して一旦美容師時代に",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 983.72,
    "end": 985.72,
    "text": "底辺を感じて",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 985.72,
    "end": 987.72,
    "text": "そこから一旦美容師頑張って",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 987.72,
    "end": 989.72,
    "text": "まずは稼いだってことなんですかね",
    "source_file": "#17_fix.mp4"
  },
  {
    "start": 989.72,
    "end": 992.72,
    "text": "第1回目としてはまず美容師頑張れっていうことで",
