[
  {
    "start": 0.0,
    "end": 29.98,
    "text": "ご視聴ありがとうございました",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 30.0,
    "end": 59.98,
    "text": "ご視聴ありがとうございました",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 60.0,
    "end": 60.82,
    "text": "よろしくお願いします",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 60.82,
    "end": 65.0,
    "text": "週刊ヘアキャンプ今週のテーマはこちら",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 65.0,
    "end": 70.66,
    "text": "必見飲み会1回分で始められる美容師の資産運用ということで",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 70.66,
    "end": 75.58,
    "text": "今ねニーサ、イデコ、保健など若手美容師でも始めやすい資産運用と",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 75.58,
    "end": 80.78,
    "text": "その具体的な運用方法について聞きたいなと思ってるんですが",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 80.78,
    "end": 82.6,
    "text": "じゃあまずは渡辺さんから",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 82.6,
    "end": 88.14,
    "text": "大前提、飲み会1回分でってなると",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 89.14,
    "end": 89.92,
    "text": "ぶっちゃけ",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 89.92,
    "end": 92.3,
    "text": "大した金額ではないかなと",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 92.3,
    "end": 94.88,
    "text": "このね、鎌形さんとかやったらね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 94.88,
    "end": 98.3,
    "text": "1回多分ね、飲み会で100万とか200万とか",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 98.3,
    "end": 100.02,
    "text": "いくとは思うんですけど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 100.02,
    "end": 102.76,
    "text": "普通としてそんな2、3万ぐらいね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 102.76,
    "end": 103.78,
    "text": "そうそうそう",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 103.78,
    "end": 104.72,
    "text": "じゃないですか",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 104.72,
    "end": 106.64,
    "text": "ってなったら2、3万って",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 106.64,
    "end": 110.22,
    "text": "まあそんなに大した資産形成は",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 110.22,
    "end": 113.4,
    "text": "まあぶっちゃけできないんじゃないかなとは思ってて",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 113.4,
    "end": 118.06,
    "text": "ただやっぱり僕は経験をするっていうのはむちゃくちゃ大事かなと",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 119.06,
    "end": 119.9,
    "text": "やりたい",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 119.9,
    "end": 124.36,
    "text": "やりたいけど一歩踏み出せないっていう方が結構多くて",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 124.36,
    "end": 127.84,
    "text": "まあそういった方々が例えばじゃあ1万円とか2万円とかで",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 127.84,
    "end": 131.92,
    "text": "まあ何かしらをこう始めていくっていうのはすごく大事なのかなと",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 131.92,
    "end": 137.36,
    "text": "今までは株もFXも不動産投資のコインも",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 137.36,
    "end": 140.9,
    "text": "まあいろいろやってたりはしてたんですけど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 140.9,
    "end": 145.82,
    "text": "まあ現状やっぱり全部投資した方がいいよねっていうのが僕らの結論であって",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 145.82,
    "end": 148.9,
    "text": "1個どれかってなったりするとちょっとリスク高かったりとか",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 148.9,
    "end": 149.34,
    "text": "なるほどなるほど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 149.34,
    "end": 151.34,
    "text": "知識が結構必要だったりもするので",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 151.34,
    "end": 156.92,
    "text": "だからこそじゃあ株も不動産も債券もいろんなものゴールドだったりとかも含め",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 156.92,
    "end": 159.96,
    "text": "全部分散してやっていくのがいわゆる投資進捗",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 159.96,
    "end": 164.44,
    "text": "これでリスク分散していきましょうっていうような考え方を教えてるんですけど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 164.44,
    "end": 168.88,
    "text": "まあそういった部分で一番僕横文字でちょっと難しいんですけど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 168.88,
    "end": 171.32,
    "text": "アセットアロケーションの考え方っていうので",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 171.32,
    "end": 173.18,
    "text": "いわゆる資産配分ですね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 173.18,
    "end": 177.26,
    "text": "でまあその全部の資産を持っておいた方がいいけど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 177.26,
    "end": 179.3,
    "text": "その割合の部分だったりとかを",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 179.3,
    "end": 181.62,
    "text": "勉強して学んでいただけたら",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 181.62,
    "end": 185.54,
    "text": "まあご自身の資産形成のやり方みたいな",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 185.54,
    "end": 188.32,
    "text": "そういったものが出来上がったりもするので",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 188.32,
    "end": 196.06,
    "text": "まずは何かしらこう自分で足を踏み込んでやってもらったらいいんじゃないかなとは思ってます",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 196.06,
    "end": 199.02,
    "text": "まずやっぱ僕も当時思ってたんですけど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 199.02,
    "end": 203.62,
    "text": "投資すると減っちゃうんでしょっていう人が多分かなり多いと思うんですよ",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 203.62,
    "end": 205.66,
    "text": "それちょっと怖くてやれないですっていう",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 205.66,
    "end": 208.92,
    "text": "ちょっとそんな人へちょっとなんかメッセージいただきたいんですけど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 209.3,
    "end": 214.92,
    "text": "あの普通に今だったらまあインフレだったりとかね物価上昇してきてるっていう状態で",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 214.92,
    "end": 216.98,
    "text": "まあいわゆるね100万円あったら",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 216.98,
    "end": 220.2,
    "text": "じゃあそれが10年後になったらどれぐらいになってんのって言ったら",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 220.2,
    "end": 222.78,
    "text": "やっぱりその100万円の価値はなくなっているよねと",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 222.78,
    "end": 227.68,
    "text": "学名は一緒だけどまあいわゆる買えるものの価値っていうのが少なくなってきてる",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 227.68,
    "end": 232.92,
    "text": "これって何もやらないだけでも損してるよっていうのが僕らの考え方",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 232.92,
    "end": 235.62,
    "text": "だからちょっとでもリスク取って",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 235.62,
    "end": 239.28,
    "text": "まあ年間なんか何パーセント3パーセントでも4パーセントでもいいかなと",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 239.3,
    "end": 244.92,
    "text": "だからまあいわゆるそのまあキャッシュフローが埋めるようなものに入れていくっていうのは大事",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 244.92,
    "end": 249.8,
    "text": "だからこの一歩踏み出さないと損するよっていうことは皆さんに言いたいなとは思います",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 249.8,
    "end": 250.72,
    "text": "なるほどそうね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 250.72,
    "end": 252.36,
    "text": "つまり何したらいいんですかね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 252.36,
    "end": 253.96,
    "text": "つまるところ",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 253.96,
    "end": 256.56,
    "text": "だからまあ投資新宅をやったらいいんじゃないかっていう",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 256.56,
    "end": 258.7,
    "text": "投資新宅大賛成",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 258.7,
    "end": 262.44,
    "text": "結局プロに運用してもらった方がいいんで",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 262.44,
    "end": 269.28,
    "text": "投資新宅だったらまあ安心性とチャレンジでやっぱ違うとは思いますけど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 269.3,
    "end": 272.54,
    "text": "まあ確実に4、5パー出れば",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 272.54,
    "end": 274.46,
    "text": "だけどそれだとさっきおっしゃってたみたいに",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 274.46,
    "end": 277.92,
    "text": "奨学だとあまり意味ないよねって思うから",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 277.92,
    "end": 283.04,
    "text": "僕は美容師はそんなのやってる前に飲み会に行けと思った",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 283.04,
    "end": 287.0,
    "text": "だって飲み会に行って",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 287.0,
    "end": 288.88,
    "text": "そんなちましょもやってんじゃねえよ",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 288.88,
    "end": 291.72,
    "text": "だって僕らの頃なんかナンパしてこいって教わったじゃないですか",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 291.72,
    "end": 295.98,
    "text": "女性ねお客さん仲良くなって髪切りに来てよと",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 295.98,
    "end": 299.3,
    "text": "でね一人だって来てくれたらカット5000円とかでしょ?",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 299.3,
    "end": 302.54,
    "text": "ねえ利回りすごく良くなっちゃう",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 302.54,
    "end": 304.18,
    "text": "そういう考え方",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 304.18,
    "end": 306.02,
    "text": "そっちの方がより最大化できるんじゃないかと",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 306.02,
    "end": 307.18,
    "text": "私はそうですね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 307.18,
    "end": 310.98,
    "text": "運用で考えたら美容師さんの少ないじゃあ1万円",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 310.98,
    "end": 314.26,
    "text": "間違いなくポケか買っといた方がいいですから",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 314.26,
    "end": 317.34,
    "text": "まあそれもね確かに見上がりしてますからね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 317.34,
    "end": 319.42,
    "text": "これちょっと前だったらラブ部買ってね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 319.42,
    "end": 321.34,
    "text": "流行る前に売り切るとかねそういう方が",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 321.34,
    "end": 324.64,
    "text": "でも言うてもやっぱ皆さん手堅くいきたいわけじゃないですか",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 324.64,
    "end": 329.14,
    "text": "だから手堅くお金損したくないっていう人は何やるべきなんですかつまり",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 329.3,
    "end": 332.78,
    "text": "でも損したくない人が投資新宅がいい",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 332.78,
    "end": 335.92,
    "text": "佐久間さんも何かちょっと難しい顔ずっとしたわけですけど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 335.92,
    "end": 341.08,
    "text": "いやいやあの興味深いテーマだなと思って",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 341.08,
    "end": 343.94,
    "text": "渡辺さん言われたみたいにやらないっていうのは機械損失",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 343.94,
    "end": 346.86,
    "text": "投資にとってすごく大事な言葉があって",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 346.86,
    "end": 349.48,
    "text": "であと投資新宅ってのすごいいいと思うんですよ",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 349.48,
    "end": 352.34,
    "text": "でその上で言ったら初心者の人にとって",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 352.34,
    "end": 354.68,
    "text": "突きづらいなかなかハードル高いなっていう中で",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 354.68,
    "end": 356.64,
    "text": "一番やりやすいのが僕はNISAだと",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 356.64,
    "end": 358.6,
    "text": "僕はなのでまずNISAやった方がいいと",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 358.6,
    "end": 362.92,
    "text": "僕はNISA5000円でいいから毎月始めましょう派なんですよ",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 362.92,
    "end": 368.18,
    "text": "なんでかっていうとまずNISAって国が選定した",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 368.18,
    "end": 370.24,
    "text": "これは大丈夫だよねっていうものになってるんで",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 370.24,
    "end": 372.98,
    "text": "基本的に大外れが少ないっていうのがあって",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 372.98,
    "end": 375.82,
    "text": "あとやるならばSBI証券とか楽天証券みたいな",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 375.82,
    "end": 378.52,
    "text": "ネット証券でやる方が手数料が安いと",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 378.52,
    "end": 381.08,
    "text": "なのでまずそこの原則を押さえた上で",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 381.08,
    "end": 383.48,
    "text": "あとはオールカントリーって言われる",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 383.48,
    "end": 385.96,
    "text": "全世界に投資する株式系とか",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 385.96,
    "end": 387.14,
    "text": "あとはS&P500みたいな",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 387.14,
    "end": 388.28,
    "text": "アメリカの主要",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 388.28,
    "end": 388.58,
    "text": "500",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 388.58,
    "end": 390.58,
    "text": "役者に投資するっていうやつの",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 390.58,
    "end": 395.16,
    "text": "その中でも手数料が安いものを選ぶっていうのが原則なんですよね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 395.16,
    "end": 397.76,
    "text": "5000円でもなぜ投資した方がいいかっていうと",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 397.76,
    "end": 401.42,
    "text": "自分にとってちょっとこれなくなったら痛いなって思うところから",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 401.42,
    "end": 403.34,
    "text": "始めるのがMISOだと思ってて",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 403.34,
    "end": 406.18,
    "text": "そうすると僕もやっぱそうだったんですけど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 406.18,
    "end": 408.6,
    "text": "日々のニュース見るようになるんですよ",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 408.6,
    "end": 410.64,
    "text": "そうするとガソリン高いな",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 410.64,
    "end": 411.92,
    "text": "カップラーメン高くなったな",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 411.92,
    "end": 413.26,
    "text": "このカップラーメンどこ作ったんだっけ",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 413.26,
    "end": 415.38,
    "text": "日清食品なんだな",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 415.38,
    "end": 416.76,
    "text": "株価が上がってんなとか",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 416.76,
    "end": 418.26,
    "text": "いろんな世の中の",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 418.26,
    "end": 420.88,
    "text": "出来事に興味を持つようになると思うんですよ",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 420.88,
    "end": 424.14,
    "text": "それってお客様との会話にもまたつながっていって",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 424.14,
    "end": 425.68,
    "text": "あとは失敗しても",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 425.68,
    "end": 428.26,
    "text": "まず小さくこけると大事なんですね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 428.26,
    "end": 431.88,
    "text": "あとは貯蓄性の要素がNISAってあるんで",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 431.88,
    "end": 433.98,
    "text": "節税的な要素もありますし",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 433.98,
    "end": 435.96,
    "text": "すごく始めやすいっていうところは",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 435.96,
    "end": 438.46,
    "text": "僕はまず5000でいいからNISAをやるってところから",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 438.46,
    "end": 439.88,
    "text": "スタートすべきかなと思ってます",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 439.88,
    "end": 442.38,
    "text": "ある程度問題点がなくても",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 442.38,
    "end": 444.1,
    "text": "実際は始められるってことですよね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 444.1,
    "end": 445.38,
    "text": "そうですね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 445.38,
    "end": 447.94,
    "text": "結構それが美容師さん多分あんまり分かってないというか",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 447.94,
    "end": 450.5,
    "text": "なんかすごくお金突っ込んで",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 450.5,
    "end": 453.0,
    "text": "しかも減ったり増えたりするんでしょみたいな",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 453.0,
    "end": 455.62,
    "text": "だったら銀行預けてたりとか安心だよねっていう人が",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 455.62,
    "end": 457.78,
    "text": "多分大多数",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 457.78,
    "end": 460.4,
    "text": "でも今銀行がねやってるしね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 460.4,
    "end": 462.52,
    "text": "なんなら最近わかりやすいのだと",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 462.52,
    "end": 464.9,
    "text": "ポンタポイントとかドコモポイントとか",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 464.9,
    "end": 468.44,
    "text": "ポイントをねペイペイポイントを投資に回そうみたいな",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 468.44,
    "end": 470.16,
    "text": "カジュアルにはなってきてますよね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 470.16,
    "end": 473.04,
    "text": "でもジュンスさんは一転しやらないわけですよね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 473.04,
    "end": 474.2,
    "text": "そうですね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 474.2,
    "end": 474.94,
    "text": "ダサいんで",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 474.94,
    "end": 477.44,
    "text": "ははははははは",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 477.94,
    "end": 482.24,
    "text": "やっぱお金儲け考えてる美容師は売れない",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 482.24,
    "end": 485.44,
    "text": "いや俺はお金儲けした方がいいと思うなって",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 485.44,
    "end": 487.54,
    "text": "美容師じゃないからね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 487.54,
    "end": 490.38,
    "text": "まあでもね僕は従業員向けにも",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 490.38,
    "end": 493.08,
    "text": "お金の勉強っていうのをやるんですよ",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 493.08,
    "end": 495.74,
    "text": "ジュンスさんと少しスタイルが違うから",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 495.74,
    "end": 497.5,
    "text": "お金の勉強はしますよ",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 497.5,
    "end": 499.32,
    "text": "お金の勉強するけど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 499.32,
    "end": 502.86,
    "text": "お金儲けを最初にしようっていう前提で考えちゃうと",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 502.86,
    "end": 504.5,
    "text": "お金儲かんないよって教えてます",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 504.5,
    "end": 505.82,
    "text": "なるほどね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 505.82,
    "end": 507.06,
    "text": "その順番を追いかけるとね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 507.06,
    "end": 507.78,
    "text": "そう順番",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 507.94,
    "end": 512.62,
    "text": "皆さんが豊かになるなんていうのをして",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 512.62,
    "end": 515.64,
    "text": "差し上げることができる人にお金が入ってくるっていう教育を",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 515.64,
    "end": 517.42,
    "text": "それはおっしゃるって言うんですよね間違いない",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 517.42,
    "end": 519.26,
    "text": "そこの順番は絶対大事ですね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 519.26,
    "end": 522.98,
    "text": "ただその上で僕はねそれを踏まえた上でやった方がいいと思うんで",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 522.98,
    "end": 525.74,
    "text": "じゃあジュンスさんはマジコのスタッフが",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 525.74,
    "end": 527.28,
    "text": "飲み会行こうぜって言って",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 527.28,
    "end": 529.6,
    "text": "いやちょっと俺ニーサーで積み立ててるんで",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 529.6,
    "end": 531.56,
    "text": "ちょっとやめときますって言ったら怒るんですか",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 531.56,
    "end": 532.22,
    "text": "いや怒るんですよ",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 532.22,
    "end": 532.92,
    "text": "それは怒るね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 532.92,
    "end": 536.14,
    "text": "じゃあ借金してでも飲みに行こうぜって",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 536.14,
    "end": 537.58,
    "text": "なるほどね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 537.94,
    "end": 542.0,
    "text": "いやでもうちニーサーはね推奨してますよ",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 542.0,
    "end": 545.96,
    "text": "たださっき言った500メーガルのやつとか",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 545.96,
    "end": 549.48,
    "text": "プロに運用してもらってっていうのは大体いいですけど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 549.48,
    "end": 553.34,
    "text": "あくまで利益が出ないと税金かかんないよって言ってるけど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 553.34,
    "end": 555.14,
    "text": "利益が出た場合の話なんですよ",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 555.14,
    "end": 557.38,
    "text": "あくまでマイナスもありますから",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 557.38,
    "end": 561.4,
    "text": "ただ銀行口座に置いといても僕は意味ないと思ってる",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 561.4,
    "end": 563.0,
    "text": "それも価値がないと思ってる",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 563.0,
    "end": 567.9,
    "text": "僕は退職金積み立てとか確実に増えていく保険がないし",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 567.94,
    "end": 572.24,
    "text": "そういった方法を進めてスタッフにそっちに全振りしろと言いますね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 572.24,
    "end": 574.34,
    "text": "年利10%以上で今回ってるので",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 574.34,
    "end": 577.06,
    "text": "そういう方がいいんじゃないって思ってますね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 577.06,
    "end": 579.12,
    "text": "ギャンブル性が一番少ないと思っています",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 579.12,
    "end": 580.3,
    "text": "ちゃんとしてるんだよな結局",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 580.3,
    "end": 580.48,
    "text": "そうなんだ",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 580.48,
    "end": 584.02,
    "text": "結局ちゃんとしてるんだよななんか反対派に見えて",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 584.02,
    "end": 586.48,
    "text": "河野さんどうですかその辺",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 586.48,
    "end": 590.0,
    "text": "普通の人が資産運用で99点を取る方法っていう本があって",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 590.0,
    "end": 591.66,
    "text": "その原文を見たんですけど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 591.66,
    "end": 595.14,
    "text": "そもそも普通の人が資産運用で99点を取るためには",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 595.14,
    "end": 597.78,
    "text": "とりあえず名刺でインデックスぶち込んどけ",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 597.78,
    "end": 597.92,
    "text": "って言って",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 597.94,
    "end": 598.76,
    "text": "っていう結論なんですよ",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 598.76,
    "end": 599.04,
    "text": "なるほど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 599.04,
    "end": 600.7,
    "text": "なんでかっていうと",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 600.7,
    "end": 604.64,
    "text": "インデックスって結局プロの基幹投資家の人たちが",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 604.64,
    "end": 607.12,
    "text": "言ったら過重平均じゃないですか",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 607.12,
    "end": 610.34,
    "text": "そのプロの人たちの戦績が上昇パーセントなんで",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 610.34,
    "end": 614.36,
    "text": "だから結局個別株買ったりとか金買ったりとか",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 614.36,
    "end": 615.88,
    "text": "何かに投資するって",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 615.88,
    "end": 618.88,
    "text": "そのプロの人たちに勝てるのっていう話なんです",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 618.88,
    "end": 621.78,
    "text": "なんで普通に美容師をやってて",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 621.78,
    "end": 624.08,
    "text": "99点の資産運用したいんだったら",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 624.08,
    "end": 626.92,
    "text": "名刺でインデックスにぶち込んでおいて",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 626.92,
    "end": 627.68,
    "text": "さっきおっしゃってた",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 627.68,
    "end": 628.94,
    "text": "焦ったロケーションっていうのは",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 628.94,
    "end": 632.1,
    "text": "シンプルにこの配分を現金とリスク資産のところで",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 632.1,
    "end": 633.64,
    "text": "どっちに配分するのっていう",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 633.64,
    "end": 635.78,
    "text": "ただこれだけの話なんですよね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 635.78,
    "end": 639.28,
    "text": "なんで美容師に必要な資産運用っていう観点で言うと",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 639.28,
    "end": 641.98,
    "text": "現場は普通に現場で頑張って",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 641.98,
    "end": 643.46,
    "text": "稼ぐ美容師になるように頑張って",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 643.46,
    "end": 647.52,
    "text": "ただ投資の個別株とかポジショニングとか考えて",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 647.52,
    "end": 649.04,
    "text": "いちいちやる必要はないから",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 649.04,
    "end": 651.2,
    "text": "シンプルにインデックスに積み立てて",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 651.2,
    "end": 652.14,
    "text": "ぶち込んでおけよって",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 652.14,
    "end": 654.44,
    "text": "それが多分一番良いと思ってて",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 654.44,
    "end": 655.7,
    "text": "それが後々美容師として",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 655.7,
    "end": 657.66,
    "text": "30歳とか",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 657.68,
    "end": 660.1,
    "text": "なってきた時に独立したいなって思い始めたら",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 660.1,
    "end": 662.18,
    "text": "そこで運用で貯まったお金で",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 662.18,
    "end": 664.4,
    "text": "次のチャレンジができる資金になるとか",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 664.4,
    "end": 665.76,
    "text": "独立するための資金になったりとか",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 665.76,
    "end": 667.3,
    "text": "っていう風になってくると思う",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 667.3,
    "end": 669.66,
    "text": "若返し自分はフェラーリ買ってますよね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 669.66,
    "end": 670.06,
    "text": "そうですね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 670.06,
    "end": 672.18,
    "text": "僕は買いたいから買いました",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 672.18,
    "end": 674.36,
    "text": "さっきの話はやってないってことですね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 674.36,
    "end": 675.1,
    "text": "自分は",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 675.1,
    "end": 677.76,
    "text": "僕は何でやってないかっていうと",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 677.76,
    "end": 679.66,
    "text": "僕はシンプルに事業に投資したほうが伸びるんで",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 679.66,
    "end": 681.18,
    "text": "例えば僕は投資",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 681.18,
    "end": 683.36,
    "text": "自分の会社の株式いっぱい子会社があって",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 683.36,
    "end": 685.56,
    "text": "その株式を持った状態って",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 685.56,
    "end": 687.3,
    "text": "結局僕の資産なわけじゃないか",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 687.3,
    "end": 687.64,
    "text": "って考えて",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 687.68,
    "end": 689.32,
    "text": "自分の持ってるお金を",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 689.32,
    "end": 691.28,
    "text": "インデックスにぶち込んで",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 691.28,
    "end": 692.74,
    "text": "年利8%とかで回すよりも",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 692.74,
    "end": 693.98,
    "text": "事業にぶち込んで",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 693.98,
    "end": 696.96,
    "text": "30%40%って上げてったほうが",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 696.96,
    "end": 698.42,
    "text": "僕は効率いいなって思うし",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 698.42,
    "end": 700.02,
    "text": "そっちのほうが負けたことないんですよね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 700.02,
    "end": 702.26,
    "text": "逆に投資みたいなので",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 702.26,
    "end": 704.88,
    "text": "僕も詐欺いっぱいあったり来たんで",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 704.88,
    "end": 707.98,
    "text": "10%とか15%とかで回る運用なんて",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 707.98,
    "end": 709.54,
    "text": "そもそも存在しないじゃないですか",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 709.54,
    "end": 711.78,
    "text": "それで成功するんだったらみんなやってるわみたいな",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 711.78,
    "end": 713.02,
    "text": "ってなるんでだったら",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 713.02,
    "end": 714.18,
    "text": "事業投資しよっていって",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 714.18,
    "end": 716.54,
    "text": "資産運用じゃなくてそっちに投資みたいな",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 716.54,
    "end": 717.64,
    "text": "考え方します",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 717.64,
    "end": 717.66,
    "text": "なるほど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 717.66,
    "end": 717.68,
    "text": "なるほど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 717.68,
    "end": 719.8,
    "text": "僕はどちらかといったら",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 719.8,
    "end": 721.18,
    "text": "インデックスって",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 721.18,
    "end": 724.22,
    "text": "世の中ではいいって言われてるけど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 724.22,
    "end": 724.98,
    "text": "今",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 724.98,
    "end": 727.64,
    "text": "銘柄選べるインデックスの中でも",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 727.64,
    "end": 729.98,
    "text": "やっぱり株しかないっていうのが僕はリスクであって",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 729.98,
    "end": 731.48,
    "text": "株だけだから",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 731.48,
    "end": 733.46,
    "text": "やっぱり確かに500銘柄で",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 733.46,
    "end": 734.58,
    "text": "分散はされてる",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 734.58,
    "end": 736.86,
    "text": "じゃあどっか個別で1銘柄",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 736.86,
    "end": 740.34,
    "text": "ここが沈んでしまっても499があるから",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 740.34,
    "end": 741.48,
    "text": "ぶっちゃけ大丈夫",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 741.48,
    "end": 743.04,
    "text": "っていうのはあると思うんですけど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 743.04,
    "end": 746.28,
    "text": "でも世界経済株ずっと右肩上がりですけど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 746.28,
    "end": 747.66,
    "text": "下がるときは全部一緒に",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 747.66,
    "end": 748.66,
    "text": "下がるんで",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 748.66,
    "end": 751.46,
    "text": "そうなったときに下がらないような資産って",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 751.46,
    "end": 752.42,
    "text": "何なのかって言ったら",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 752.42,
    "end": 754.28,
    "text": "今で言うと債券もそうだし",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 754.28,
    "end": 756.48,
    "text": "ゴールドもそうだと思うし",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 756.48,
    "end": 757.68,
    "text": "ちょっと前だったら",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 757.68,
    "end": 759.8,
    "text": "ゴールドも一緒に株と下がっちゃったんで",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 759.8,
    "end": 761.92,
    "text": "今デジタルゴールドって言われてるような",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 761.92,
    "end": 763.24,
    "text": "ビットだったりとか",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 763.24,
    "end": 766.28,
    "text": "ああいったものを大体資産として持っておく",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 766.28,
    "end": 770.28,
    "text": "っていうのはちょっとリスクを抑えれるかなと",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 770.28,
    "end": 772.88,
    "text": "こういった部分がちゃんと分かった上で",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 772.88,
    "end": 774.6,
    "text": "僕始めるんだったらいいと思うんですよ",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 774.6,
    "end": 777.64,
    "text": "NISAでインデックスでもちろんそれも大事",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 777.64,
    "end": 780.96,
    "text": "だけどこういったことがあるんだよっていうことを",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 780.96,
    "end": 784.1,
    "text": "大体の方がやってたらもう増えるっていう",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 784.1,
    "end": 785.92,
    "text": "風なイメージを持ってるから",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 785.92,
    "end": 788.88,
    "text": "そうじゃないんだよっていうところが分かった上で",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 788.88,
    "end": 791.26,
    "text": "始めるんだったらいいかなと",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 791.26,
    "end": 792.14,
    "text": "だから僕さっき言ってた",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 792.14,
    "end": 794.44,
    "text": "アセットアロケーションの考え方っていうのが",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 794.44,
    "end": 795.82,
    "text": "始めるんだったら",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 795.82,
    "end": 798.7,
    "text": "もう言ったらちゃんとこれで資産形成するって",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 798.7,
    "end": 799.76,
    "text": "決めるんだったら",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 799.76,
    "end": 803.76,
    "text": "そこまでは大前提分かっておいた状態でやらないと",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 803.76,
    "end": 806.22,
    "text": "意味がないんじゃないかなとは思ってます",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 806.22,
    "end": 807.28,
    "text": "なるほど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 807.64,
    "end": 811.4,
    "text": "その話で言うと結局若い子も怖くてできませんね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 811.4,
    "end": 812.52,
    "text": "今の話聞いてると",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 812.52,
    "end": 816.3,
    "text": "だからこそ最初はもう5000円からスタートする",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 816.3,
    "end": 820.12,
    "text": "今の渡辺さんのおっしゃることってもう大正解だったら",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 820.12,
    "end": 821.84,
    "text": "お金を結構持ってる人は",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 821.84,
    "end": 824.92,
    "text": "そうやって分散をするってことにチャレンジできると思うけど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 824.92,
    "end": 826.32,
    "text": "まずそのレベルに達してない人は",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 826.32,
    "end": 829.26,
    "text": "まずはなくなったもいいお金の中で",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 829.26,
    "end": 830.36,
    "text": "チャレンジするってのが大事",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 830.36,
    "end": 833.56,
    "text": "だから僕は飲み会1回分の5000円からスタートして",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 833.56,
    "end": 835.14,
    "text": "それが半分になるかもしれないけど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 835.14,
    "end": 837.48,
    "text": "まあ飲み会1回なくなった分ぐらいで",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 837.48,
    "end": 838.76,
    "text": "済むわけじゃないですか",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 838.76,
    "end": 840.98,
    "text": "なのでそういうところから始めていくのがいいかなと",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 840.98,
    "end": 843.16,
    "text": "なのであとは機械損失って言って",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 843.16,
    "end": 845.3,
    "text": "やらないことが一番喪失だと僕は思うんで",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 845.3,
    "end": 847.86,
    "text": "始めるところからちょっとずつ練習していけばいいんじゃないかな",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 847.86,
    "end": 849.44,
    "text": "なるほど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 849.44,
    "end": 852.02,
    "text": "ちょっとねまだまだ話足りないんですけども",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 852.02,
    "end": 854.9,
    "text": "まずは今日のまとめとしては",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 854.9,
    "end": 857.14,
    "text": "ちょっとした奨学から",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 857.14,
    "end": 859.22,
    "text": "まずは兄さん始めろこれでいいですか",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 859.22,
    "end": 860.06,
    "text": "僕はそう思います",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 860.06,
    "end": 861.1,
    "text": "わかりました",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 861.1,
    "end": 863.0,
    "text": "じゃあまずはねちょっと見てる皆さんね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 863.0,
    "end": 865.72,
    "text": "結局何やったらいいのになってると思うけど",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 865.72,
    "end": 866.6,
    "text": "まず佐久間さんを信じて",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 866.6,
    "end": 867.28,
    "text": "佐久間さん信じてないぞ",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 867.48,
    "end": 868.24,
    "text": "信じていきましょう",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 868.24,
    "end": 870.46,
    "text": "飲み会で兄さん始めましょう",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 870.46,
    "end": 872.26,
    "text": "まずは始めるところから",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 872.26,
    "end": 873.66,
    "text": "飲みに行ったほうがいいと思うけどな",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 873.66,
    "end": 876.02,
    "text": "飲みにはいったほうがいいですね",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 876.02,
    "end": 878.2,
    "text": "飲みに行って兄さんもやる",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 878.2,
    "end": 878.94,
    "text": "どっちもやりましょう",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 878.94,
    "end": 882.32,
    "text": "ということで次週もこのメンバーでお届けします",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 882.32,
    "end": 883.6,
    "text": "来週のテーマは",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 883.6,
    "end": 885.86,
    "text": "美容師はセンス?投資もセンス?",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 886.44,
    "end": 888.42,
    "text": "月が資産に変わる瞬間",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 888.42,
    "end": 890.9,
    "text": "というテーマでお届けしていきたいと思います",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 890.9,
    "end": 892.64,
    "text": "それでは次週もまたご覧ください",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 897.48,
    "end": 927.46,
    "text": "ご視聴ありがとうございました",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 927.48,
    "end": 957.46,
    "text": "ご視聴ありがとうございました",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 957.48,
    "end": 987.46,
    "text": "ご視聴ありがとうございました",
    "source_file": "#18_fix.mp4"
  },
  {
    "start": 987.48,
    "end": 1017.46,
    "text": "ご視聴ありがとうございました",
    "source_file": "#18_fix.mp4"
  }
]