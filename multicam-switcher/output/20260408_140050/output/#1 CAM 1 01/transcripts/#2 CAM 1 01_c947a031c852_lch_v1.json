[
  {
    "start": 0.0,
    "end": 3.6,
    "text": "最初に渡辺さんに僕振りますね、それ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 3.6,
    "end": 4.8,
    "text": "はい",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 4.8,
    "end": 9.7,
    "text": "そこでちょっと逆に渡辺さんか佐久間さんに ちょっといい感じにパスしてもらえたりすると",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 9.7,
    "end": 11.5,
    "text": "分かりました",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 11.5,
    "end": 13.2,
    "text": "いいかなっていう感じです",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 13.2,
    "end": 16.0,
    "text": "このテーマがむずい",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 16.0,
    "end": 17.5,
    "text": "いや、そうなんですか?",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 17.5,
    "end": 20.8,
    "text": "だって飲み会1回分で",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 20.8,
    "end": 21.3,
    "text": "まあ確かに",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 21.3,
    "end": 23.4,
    "text": "では飲み会1回の金額が違うってさ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 23.4,
    "end": 25.7,
    "text": "そう、だからそれをそこちょっと 今言おうと思ってるからちょっと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 25.7,
    "end": 30.4,
    "text": "で、100万ぐらい使う?",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 30.4,
    "end": 33.1,
    "text": "それ俺が言いたかったよな",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 33.1,
    "end": 34.9,
    "text": "そのいいですね、そのちょっかいで",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 34.9,
    "end": 37.7,
    "text": "この感じで、ポンギでね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 37.7,
    "end": 38.7,
    "text": "僕が言うから",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 38.7,
    "end": 41.7,
    "text": "今日初めましてだけどね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 41.7,
    "end": 44.7,
    "text": "もうラウンジだと思ってもらって",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 44.7,
    "end": 47.0,
    "text": "はい",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 47.0,
    "end": 52.6,
    "text": "はい",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 52.6,
    "end": 55.3,
    "text": "はい、皆さん今週もよろしくお願いします",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 55.3,
    "end": 55.6,
    "text": "よろしくお願いします",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 55.6,
    "end": 56.3,
    "text": "お願いします",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 56.3,
    "end": 60.0,
    "text": "はい、週刊ヘアキャンプ今週のテーマはこちら",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 60.0,
    "end": 65.6,
    "text": "必見飲み会1回分で始められる 美容師の資産運用ということで",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 65.6,
    "end": 70.2,
    "text": "今ね、NISA、iDeCo、保険など若手美容師でも 始めやすい資産運用と",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 70.2,
    "end": 74.0,
    "text": "その具体的な運用方法について",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 74.0,
    "end": 76.1,
    "text": "プロフェッショナルに特にお二人の方から",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 76.1,
    "end": 79.9,
    "text": "ちょっとまずメインでお聞きしたいな と思ってるんですが",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 79.9,
    "end": 81.4,
    "text": "じゃあまず渡辺さんから",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 81.4,
    "end": 84.4,
    "text": "ちょっとズバリどうなんですかと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 84.4,
    "end": 85.2,
    "text": "NISA、iDeCo",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 85.2,
    "end": 86.7,
    "text": "資産運用、保険",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 86.7,
    "end": 88.6,
    "text": "その辺結構詳しい人って",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 88.6,
    "end": 91.4,
    "text": "あんまり実際美容師まだまだ少ないと思うんですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 91.4,
    "end": 95.3,
    "text": "その辺はちょっとどんなメリットがあるか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 95.3,
    "end": 96.6,
    "text": "なぜやった方がいいのかっていうのを",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 96.6,
    "end": 98.6,
    "text": "ちょっと伺いたいなと思ってるんですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 98.6,
    "end": 99.8,
    "text": "はい",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 99.8,
    "end": 105.6,
    "text": "大前提、飲み会1回分でってなると",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 105.6,
    "end": 108.8,
    "text": "ぶっちゃけ大した金額ではないかなと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 108.8,
    "end": 111.6,
    "text": "このね、鎌方さんとかやったらね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 111.6,
    "end": 115.0,
    "text": "1回多分ね、飲み会で100万とか200万とか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 115.2,
    "end": 116.8,
    "text": "いくとは思うんですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 116.8,
    "end": 119.6,
    "text": "普通の人ってそんな2、3万ぐらいね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 119.6,
    "end": 121.7,
    "text": "そうそうそう、じゃないですか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 121.7,
    "end": 124.3,
    "text": "ってなったら2、3万って",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 124.3,
    "end": 127.7,
    "text": "まあそんなに大した資産形成は",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 127.7,
    "end": 131.0,
    "text": "まあぶっちゃけできないんじゃないかなとは思ってて",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 131.0,
    "end": 134.4,
    "text": "ただやっぱり僕は経験をするっていうのは",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 134.4,
    "end": 137.1,
    "text": "むちゃくちゃ大事かなと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 137.1,
    "end": 140.8,
    "text": "皆さん大体の方がやりたいけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 140.8,
    "end": 144.4,
    "text": "一歩踏み出せないっていう方が結構多くて",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 144.4,
    "end": 147.9,
    "text": "そういった方々が例えば1万円とか2万円とかで",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 147.9,
    "end": 152.2,
    "text": "何かしらを始めていくっていうのはすごく大事なのかなと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 152.2,
    "end": 154.2,
    "text": "で、僕一応投資新宅",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 154.2,
    "end": 160.2,
    "text": "まあ今までは株もFXも不動産投資のコインも",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 160.2,
    "end": 163.7,
    "text": "まあいろいろやってたりはしてたんですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 163.7,
    "end": 166.9,
    "text": "まあ現状やっぱり全部投資した方がいいよねっていうのが",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 166.9,
    "end": 168.6,
    "text": "僕らの結論であって",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 168.6,
    "end": 172.1,
    "text": "1個どれかってなったりするとちょっとリスク高かったりとか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 172.1,
    "end": 174.4,
    "text": "知識が結構必要だったりもするので",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 174.4,
    "end": 177.6,
    "text": "だからこそじゃあ株も不動産も債券も",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 177.6,
    "end": 180.0,
    "text": "いろんなものゴールドだったりとかも含め",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 180.0,
    "end": 183.5,
    "text": "全部分散してやっていくのがいわゆる投資新宅",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 183.5,
    "end": 187.8,
    "text": "これでリスク分散していきましょうっていうような考え方を教えてるんですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 187.8,
    "end": 190.0,
    "text": "まあそういった部分で一番僕",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 190.0,
    "end": 191.8,
    "text": "横文字でちょっと難しいんですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 191.8,
    "end": 194.1,
    "text": "アセットアロケーションの考え方っていって",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 194.1,
    "end": 197.0,
    "text": "いわゆる資産配分ですね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 197.0,
    "end": 200.0,
    "text": "で、全部の資産を持っといた方がいいけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 200.0,
    "end": 204.2,
    "text": "その割合の部分だったりとかを勉強して学んでいただけたら",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 204.4,
    "end": 208.5,
    "text": "ご自身の資産形成のやり方みたいな",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 208.5,
    "end": 211.5,
    "text": "そういったものが出来上がったりもするので",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 211.5,
    "end": 214.8,
    "text": "まずは何かしらこう自分で",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 214.8,
    "end": 219.0,
    "text": "足を踏み込んでやってもらったらいいんじゃないかなとは思ってます",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 219.0,
    "end": 221.9,
    "text": "まずやっぱ僕も当時思ってたんですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 221.9,
    "end": 224.3,
    "text": "やっぱこうお金お給料いただく",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 224.3,
    "end": 226.3,
    "text": "まず銀行口座入りますよね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 226.3,
    "end": 231.5,
    "text": "そこで一旦その銀行口座にこの数十万貯まってて",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 231.5,
    "end": 232.7,
    "text": "安心しちゃって",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 232.7,
    "end": 234.2,
    "text": "それは間違いなく減らない",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 234.2,
    "end": 235.8,
    "text": "減らないじゃないですか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 235.8,
    "end": 242.3,
    "text": "だからその投資すると減っちゃうんでしょっていう人が多分かなり多いと思うんですよ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 242.3,
    "end": 244.6,
    "text": "それちょっと怖くてやれないですっていう",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 244.6,
    "end": 248.5,
    "text": "ちょっとそんな人へちょっと何かメッセージいただきたいんですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 248.5,
    "end": 251.3,
    "text": "普通に今だったらインフレだったりとかね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 251.3,
    "end": 253.6,
    "text": "物価上昇してきてるっていう状態で",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 253.6,
    "end": 255.5,
    "text": "いわゆる100万円あったら",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 255.5,
    "end": 258.7,
    "text": "じゃあそれが10年後になったらどれぐらいになってるのって言ったら",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 258.7,
    "end": 261.6,
    "text": "やっぱりその100万円の価値はなくなってるよねと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 261.6,
    "end": 263.3,
    "text": "額面は一緒だけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 264.2,
    "end": 266.6,
    "text": "その価値っていうのが少なくなってきてる",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 266.6,
    "end": 272.2,
    "text": "これって何もやらないだけでも損してるよっていうのが僕らの考え方",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 272.2,
    "end": 274.8,
    "text": "だからちょっとでもリスクとって",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 274.8,
    "end": 278.5,
    "text": "年間何パーセント3パーセントでも4パーセントでもいいから",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 278.5,
    "end": 283.8,
    "text": "いわゆるそのキャッシュフローが埋めるようなものに入れていくっていうのは大事",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 283.8,
    "end": 289.4,
    "text": "だからこの一歩踏み出さないと損するよってことは皆さんに言いたいなとは思います",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 289.4,
    "end": 292.0,
    "text": "つまり何したらいいんですかね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 292.0,
    "end": 292.8,
    "text": "詰まるところね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 292.8,
    "end": 294.0,
    "text": "詰まるところをね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 294.2,
    "end": 296.2,
    "text": "投資信託をやったらいいんじゃないかっていう",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 296.2,
    "end": 298.2,
    "text": "投資信託大賛成",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 298.2,
    "end": 301.2,
    "text": "分散投資が一番大事かなっていう",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 301.2,
    "end": 304.2,
    "text": "結局プロに運用してもらった方がいい",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 304.2,
    "end": 311.2,
    "text": "投資信託だったら安心性とチャレンジでやっぱ違うとは思いますけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 311.2,
    "end": 314.2,
    "text": "確実に4、5パー出れば",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 314.2,
    "end": 315.2,
    "text": "年利4、5パー",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 315.2,
    "end": 317.2,
    "text": "だけどそれだとさっきおっしゃってたみたいに",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 317.2,
    "end": 321.2,
    "text": "奨学だとあまり意味ないよねって思うから",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 321.2,
    "end": 323.2,
    "text": "僕は美容師はそんなのやってる前に",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 324.2,
    "end": 326.2,
    "text": "飲み会に行けと思った",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 326.2,
    "end": 327.2,
    "text": "逆に",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 327.2,
    "end": 332.2,
    "text": "だって飲み会に行って",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 332.2,
    "end": 335.2,
    "text": "僕らの頃なんかナンパしてこいって教わったじゃないですか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 335.2,
    "end": 339.2,
    "text": "女性お客さん仲良くなって髪切りに来てよと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 339.2,
    "end": 343.2,
    "text": "一人だって来てくれたらカットで5000円とかでしょ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 343.2,
    "end": 346.2,
    "text": "利回りすごく良くなるから",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 346.2,
    "end": 347.2,
    "text": "そういう考え方",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 347.2,
    "end": 349.2,
    "text": "そっちの方がより最大化できるんじゃないか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 349.2,
    "end": 351.2,
    "text": "私はそうですね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 351.2,
    "end": 352.2,
    "text": "運用なんだって",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 352.2,
    "end": 353.2,
    "text": "運用で考えたら",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 353.2,
    "end": 356.2,
    "text": "美容師さんの少ないじゃあ1万円",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 356.2,
    "end": 358.2,
    "text": "今回の飲み代が分からないですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 358.2,
    "end": 360.2,
    "text": "5000円から1万円だとしたら",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 360.2,
    "end": 363.2,
    "text": "間違いなくポケかかっといた方がいいですから",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 363.2,
    "end": 366.2,
    "text": "それも確かに見上がりしてますからね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 366.2,
    "end": 368.2,
    "text": "ちょっと前だったらラブブ買って",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 368.2,
    "end": 370.2,
    "text": "流行る前に売り切るとかそういう方が",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 370.2,
    "end": 373.2,
    "text": "YouTubeは皆さん手堅く行きたいわけじゃないですか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 373.2,
    "end": 377.2,
    "text": "そんなギャンブル性求めたくないわけですよね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 377.2,
    "end": 382.2,
    "text": "手堅くお金損したくないっていう人は何やるべきなんですかつまり",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 382.2,
    "end": 385.2,
    "text": "そうしたくない人が投資信託がいいと思う",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 385.2,
    "end": 388.2,
    "text": "小学からでもまずは始めてもいい",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 388.2,
    "end": 391.2,
    "text": "そこでNISAの制度を使ったりとか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 391.2,
    "end": 393.2,
    "text": "iDeCoの制度を使うのもそうですし",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 393.2,
    "end": 396.2,
    "text": "日本の制度でいうとそれだけじゃなく",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 396.2,
    "end": 399.2,
    "text": "いわゆる投資信託って言われてるようなもの",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 399.2,
    "end": 402.2,
    "text": "いわゆるNISA、iDeCoって税金かかんないからいいよね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 402.2,
    "end": 405.2,
    "text": "だったりとかそういったメリットがあるんですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 405.2,
    "end": 409.2,
    "text": "それ以外に商品のラインナップがやっぱり",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 409.2,
    "end": 411.2,
    "text": "僕らからするとちょっと少なかったりもするので",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 411.2,
    "end": 415.2,
    "text": "よりまんべんなく分散するんだったら",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 415.2,
    "end": 417.2,
    "text": "投資信託っていう枠組み",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 417.2,
    "end": 420.2,
    "text": "NISAとかiDeCoのない枠組みでやっていくのは",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 420.2,
    "end": 422.2,
    "text": "もちろん税金はかかってくるんですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 422.2,
    "end": 424.2,
    "text": "一番いいんじゃないかなと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 424.2,
    "end": 428.2,
    "text": "だから次のフェーズでそういったことを考えていってもいいんじゃないかなと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 428.2,
    "end": 431.2,
    "text": "ゆうずさんとか鎌田君はそんなことよりも",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 431.2,
    "end": 434.2,
    "text": "自己投資で成功したお二人ですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 434.2,
    "end": 436.2,
    "text": "ちょっと先週と同じ感じになっちゃいますけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 436.2,
    "end": 438.2,
    "text": "まだちょっとあれですね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 438.2,
    "end": 439.2,
    "text": "そうですね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 439.2,
    "end": 440.2,
    "text": "ゆるいですね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 440.2,
    "end": 445.2,
    "text": "言うてもじゃあ今一般のアシスタントの子から",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 445.2,
    "end": 449.2,
    "text": "始めるべきか否かで言ったら始めた方がいいよっていうお話ですよね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 449.2,
    "end": 454.2,
    "text": "一般のある程度稼いでからだとは思うので",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 454.2,
    "end": 455.2,
    "text": "僕は",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 455.2,
    "end": 457.2,
    "text": "手取り十何万じゃちょっとまだ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 457.2,
    "end": 459.2,
    "text": "きついんじゃないですかね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 459.2,
    "end": 462.2,
    "text": "別に千円とか百円とかでもできなくはないんですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 462.2,
    "end": 465.2,
    "text": "何の意味もないっちゃ何の意味もない",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 465.2,
    "end": 467.2,
    "text": "ただやり方とかは分かると",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 467.2,
    "end": 469.2,
    "text": "なるほどなるほど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 469.2,
    "end": 472.2,
    "text": "たくまさんも難しい顔ずっとしたんですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 472.2,
    "end": 475.2,
    "text": "いやいや興味深いテーマだなと思って",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 475.2,
    "end": 478.2,
    "text": "やっぱり渡辺さんが言われたみたいに",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 478.2,
    "end": 480.2,
    "text": "やらないっていうのは機械損失",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 480.2,
    "end": 483.2,
    "text": "投資にとってすごく大事な言葉があって",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 483.2,
    "end": 486.2,
    "text": "あと投資新宅ってすごくいいと思うんですよ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 486.2,
    "end": 488.2,
    "text": "その上で言ったら初心者の人にとって",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 488.2,
    "end": 491.2,
    "text": "とっつきづらいなかなかハードル高いなっていう中で",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 491.2,
    "end": 493.2,
    "text": "一番やりやすいのが僕はNISAだと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 493.2,
    "end": 495.2,
    "text": "僕はなのでまずNISAやった方がいいと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 495.2,
    "end": 498.2,
    "text": "僕はNISA5000円でいいから毎月始めましょう派なんですよ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 499.2,
    "end": 503.2,
    "text": "なんでかっていうと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 503.2,
    "end": 507.2,
    "text": "まずNISAって国が選定した",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 507.2,
    "end": 509.2,
    "text": "これは大丈夫だよねっていうものになってるんで",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 509.2,
    "end": 512.2,
    "text": "基本的に大外れが少ないっていうのがあって",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 512.2,
    "end": 515.2,
    "text": "あとやるならばSBI証券とか楽天証券みたいな",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 515.2,
    "end": 517.2,
    "text": "ネット証券でやる方が手数料が安いと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 517.2,
    "end": 520.2,
    "text": "なのでまずそこの原則を押さえた上で",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 520.2,
    "end": 522.2,
    "text": "あとはオールカントリーって言われる",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 522.2,
    "end": 525.2,
    "text": "全世界に投資する株式系とか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 525.2,
    "end": 529.2,
    "text": "あとはS&P500みたいなアメリカの主要誤約者に投資するっていうやつの",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 529.2,
    "end": 533.2,
    "text": "その中でも投資信託料が安いもの",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 533.2,
    "end": 537.2,
    "text": "手数料が安いものを選ぶっていうのが原則なんですよね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 537.2,
    "end": 540.2,
    "text": "5000円でもなぜ投資した方がいいかっていうと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 540.2,
    "end": 543.2,
    "text": "自分にとってちょっとこれなくなったら痛いなって思うところから",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 543.2,
    "end": 545.2,
    "text": "始めるのがMISOだと思ってて",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 545.2,
    "end": 548.2,
    "text": "そうすると僕もやっぱそうだったんですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 548.2,
    "end": 551.2,
    "text": "日々のニュース見るようになるんですよ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 551.2,
    "end": 556.2,
    "text": "そうするとなんで普段こんなこと起こってんのかなみたいなことが",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 556.2,
    "end": 558.2,
    "text": "例えばガソリン高いな",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 559.2,
    "end": 562.2,
    "text": "安くなったなとかカップラーメン高くなったな",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 562.2,
    "end": 564.2,
    "text": "このカップラーメンどこ作ったんだっけ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 564.2,
    "end": 566.2,
    "text": "日清食品なんだな",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 566.2,
    "end": 568.2,
    "text": "株価下がってんなとか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 568.2,
    "end": 572.2,
    "text": "いろんな世の中の出来事に興味を持つようになると思うんですよ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 572.2,
    "end": 575.2,
    "text": "それってお客様との会話にもまたつながっていって",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 575.2,
    "end": 579.2,
    "text": "またそういうプラスの方にも働くと思いますし",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 579.2,
    "end": 583.2,
    "text": "あとは失敗してもまず小さくこけるってのが大事なんですよね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 583.2,
    "end": 587.2,
    "text": "あとは貯蓄性の要素が2つあってあるんで",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 587.2,
    "end": 588.2,
    "text": "節税というか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 589.2,
    "end": 591.2,
    "text": "節税的な要素もありますし",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 591.2,
    "end": 593.2,
    "text": "すごく始めやすいっていうところは",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 593.2,
    "end": 594.2,
    "text": "僕はまず5000でいいから",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 594.2,
    "end": 598.2,
    "text": "NISAをやるっていうところからスタートすべきかなと思ってます",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 598.2,
    "end": 601.2,
    "text": "つまりある程度問題がなくても",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 601.2,
    "end": 603.2,
    "text": "実際は始められるってことですよね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 603.2,
    "end": 604.2,
    "text": "そうですね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 604.2,
    "end": 607.2,
    "text": "結構それが美容師さん多分あんまり分かってないというか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 607.2,
    "end": 609.2,
    "text": "すごくお金突っ込んで",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 609.2,
    "end": 612.2,
    "text": "しかも減ったり増えたりするんでしょうみたいな",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 612.2,
    "end": 616.2,
    "text": "だったら銀行預けてた人が安心だよねっていう人が多分大多数",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 616.2,
    "end": 618.2,
    "text": "そこのなんかちょっとね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 618.2,
    "end": 621.2,
    "text": "でも今銀行がねやってるしね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 621.2,
    "end": 623.2,
    "text": "なんなら最近分かりやすいのだと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 623.2,
    "end": 625.2,
    "text": "ポンタポイントとかドコモポイントとか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 625.2,
    "end": 629.2,
    "text": "ポイントをねペイペイポイントを投資に回そうみたいな",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 629.2,
    "end": 631.2,
    "text": "カジュアルにはなってきてますよね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 631.2,
    "end": 634.2,
    "text": "でもじゅんさんは1点しやらない",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 634.2,
    "end": 636.2,
    "text": "そうですねダサいんで",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 639.2,
    "end": 643.2,
    "text": "やっぱお金儲け考えてる美容師は売れない",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 643.2,
    "end": 646.2,
    "text": "いや俺はお金儲けした方がいいと思うなって",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 646.2,
    "end": 647.2,
    "text": "美容師じゃないからね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 648.2,
    "end": 654.2,
    "text": "まあでもね僕は従業員向けにもお金の勉強っていうのをやるんですよ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 654.2,
    "end": 657.2,
    "text": "だからじゅんさんとは少しスタイルが違うから",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 657.2,
    "end": 659.2,
    "text": "お金の勉強はしますよ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 659.2,
    "end": 664.2,
    "text": "お金の勉強するけどお金儲けを最初にしようっていう前提で考えちゃうと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 664.2,
    "end": 666.2,
    "text": "お金儲かんないよって教えてます",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 666.2,
    "end": 667.2,
    "text": "なるほどね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 667.2,
    "end": 668.2,
    "text": "その順番を",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 668.2,
    "end": 669.2,
    "text": "そう順番",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 669.2,
    "end": 674.2,
    "text": "皆さんが豊かになるなんていうのをして",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 674.2,
    "end": 677.2,
    "text": "差し上げることができる人にお金が入ってくるっていう教育をしてる",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 677.2,
    "end": 679.2,
    "text": "それはおっしゃると言うんですね間違いない",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 679.2,
    "end": 681.2,
    "text": "そこの順番は絶対大事ですね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 681.2,
    "end": 685.2,
    "text": "ただその上で僕はねそれを踏まえた上でやった方がいいと思うんで",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 685.2,
    "end": 689.2,
    "text": "じゃあじゅんさんはマジコのスタッフが飲み会行こうぜって言って",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 689.2,
    "end": 693.2,
    "text": "いやちょっと俺NISAで積み立ててるんでちょっとやめときますって言ったら怒るんですか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 693.2,
    "end": 694.2,
    "text": "いや怒るんですよ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 694.2,
    "end": 695.2,
    "text": "それは怒らない",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 695.2,
    "end": 696.2,
    "text": "それは怒らない",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 696.2,
    "end": 698.2,
    "text": "借金してでも飲みに行こうぜっていう",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 698.2,
    "end": 700.2,
    "text": "なるほどね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 700.2,
    "end": 702.2,
    "text": "NISAやった上で借金して行った方がいい",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 702.2,
    "end": 706.2,
    "text": "いやでもうちNISAはね推奨してますよ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 706.2,
    "end": 710.2,
    "text": "たださっき言った500メーガルのやつとか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 710.2,
    "end": 714.2,
    "text": "プロに運用してもらってっていうのは大体いいですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 714.2,
    "end": 717.2,
    "text": "あくまで利益が出ないと税金かかんないよって言ってるけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 717.2,
    "end": 719.2,
    "text": "利益が出た場合の話なんですよ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 719.2,
    "end": 721.2,
    "text": "あくまでマイナスもありますから",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 721.2,
    "end": 725.2,
    "text": "ただ銀行口座に置いといても僕は意味ないと思ってるんですよ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 725.2,
    "end": 727.2,
    "text": "それも価値がないと思ってるんで",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 727.2,
    "end": 730.2,
    "text": "僕は退職金積み立てとか確実に増えていく",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 730.2,
    "end": 735.2,
    "text": "保険がないしそういった方を勧めてスタッフにそっちに全振りしろと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 735.2,
    "end": 736.2,
    "text": "なるほど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 736.2,
    "end": 741.2,
    "text": "年利10%以上で今回ってるのでそういう方がいいんじゃないって思ってますね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 741.2,
    "end": 743.2,
    "text": "ギャンブル性が一番少ないと思っています",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 743.2,
    "end": 745.2,
    "text": "ちゃんとしてんだよな結局",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 745.2,
    "end": 746.2,
    "text": "そうなんだ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 746.2,
    "end": 749.2,
    "text": "結局ちゃんとしてるんだよななんか反対派に見えて",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 749.2,
    "end": 752.2,
    "text": "川田さんどうですかその辺",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 752.2,
    "end": 758.2,
    "text": "僕コラム結構本好きで本でなんだっけな",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 758.2,
    "end": 762.2,
    "text": "普通の人が資産運用で99点を取る方法っていう本があって",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 762.2,
    "end": 766.2,
    "text": "その原文をこの間全部バーって見てこの番組決まってから見たんですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 766.2,
    "end": 771.2,
    "text": "なんかそもそも普通の人が資産運用で99点を取るためには",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 771.2,
    "end": 774.2,
    "text": "とりあえず脳死でインデックスぶち込んどけっていう結論なんですよ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 774.2,
    "end": 775.2,
    "text": "なるほど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 775.2,
    "end": 780.2,
    "text": "なんでかっていうとインデックスって結局プロの基幹投資家の人たちが",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 780.2,
    "end": 783.2,
    "text": "言ったら過重平均じゃないですか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 783.2,
    "end": 786.2,
    "text": "そのプロの人たちの戦績が上昇パーセントなんで",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 786.2,
    "end": 792.2,
    "text": "だから結局個別株買ったりとか金買ったりとか何かに投資するって",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 792.2,
    "end": 795.2,
    "text": "そのプロの人たちに勝てるのっていう話なんですよ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 795.2,
    "end": 800.2,
    "text": "なんで普通に美容師をやってて99点の資産運用したいんだったら",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 800.2,
    "end": 804.2,
    "text": "脳死でインデックスにぶち込んでおいてさっきおっしゃってた",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 804.2,
    "end": 807.2,
    "text": "焦ったロケーションっていうのはシンプルにこの配分を",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 807.2,
    "end": 810.2,
    "text": "現金とリスク資産のところでどっちに配分するのっていう",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 810.2,
    "end": 812.2,
    "text": "ただこれだけの話なんですよね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 812.2,
    "end": 816.2,
    "text": "なんで美容師に必要な資産運用っていう観点で言うと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 816.2,
    "end": 820.2,
    "text": "現場は普通に現場で頑張って稼ぐ美容師になるように頑張って",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 820.2,
    "end": 824.2,
    "text": "ただ投資の個別株とかポジショニングとか考えて",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 824.2,
    "end": 828.2,
    "text": "いちいちやる必要はないからシンプルにインデックスに積み立てて",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 828.2,
    "end": 831.2,
    "text": "ぶち込んでおけよってそれが多分一番良いと思ってて",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 831.2,
    "end": 836.2,
    "text": "それが後々美容師として30歳とかになってきた時に独立したいなと思い始めたら",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 836.2,
    "end": 841.2,
    "text": "そこで運用で貯まったお金で次のチャレンジができる資金になるとか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 841.2,
    "end": 844.2,
    "text": "独立するための資金になったりとかっていう風になってくる",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 844.2,
    "end": 846.2,
    "text": "若彼氏自分はフェラーリ買ってますよね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 846.2,
    "end": 849.2,
    "text": "そうですね僕は買いたいから買いました",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 849.2,
    "end": 852.2,
    "text": "だけど原橋はやってないってことですね自分は",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 852.2,
    "end": 854.2,
    "text": "そうですね僕は何でやってないかっていうと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 854.2,
    "end": 856.2,
    "text": "僕はシンプルに事業に投資した方が伸びるんで",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 856.2,
    "end": 860.2,
    "text": "例えば僕は自分の会社の株式でいっぱい子会社があって",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 860.2,
    "end": 864.2,
    "text": "その株式を持った状態って結局僕の資産なわけじゃないかって考えた時に",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 864.2,
    "end": 869.2,
    "text": "じゃあ自分の持ってるお金をインデックスにぶち込んで年利8%とかで回すよりも",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 869.2,
    "end": 875.2,
    "text": "事業にぶち込んで30%40%って上げてった方が僕は効率いいなって思うし",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 875.2,
    "end": 877.2,
    "text": "そっちの方が負けたことないんですよね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 877.2,
    "end": 882.2,
    "text": "逆に投資みたいなので変な案件いっぱい僕も詐欺いっぱいあったり来たんで",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 882.2,
    "end": 884.2,
    "text": "言うたら10%とか15%とかいっぱいあったりするから",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 884.2,
    "end": 886.2,
    "text": "で回る運用なんてそもそも存在しないじゃないですか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 886.2,
    "end": 888.2,
    "text": "それで成功するんだったらみんなやってるわみたいな",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 888.2,
    "end": 891.2,
    "text": "ってなるんでだったら事業投資しようっていって",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 891.2,
    "end": 895.2,
    "text": "資産運用じゃなくてそっちに投資みたいな感じの考え方しますね僕は",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 895.2,
    "end": 898.2,
    "text": "なんかポジション的にちょっとややこしくなってきてるんですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 898.2,
    "end": 903.2,
    "text": "もっといいもんあるでみたいな話になっちゃってるんですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 903.2,
    "end": 906.2,
    "text": "その話でお二人ちょっと回収しようと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 906.2,
    "end": 908.2,
    "text": "スペシャリスト",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 908.2,
    "end": 911.2,
    "text": "いやいやいいと思いますよ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 911.2,
    "end": 912.2,
    "text": "インデックスも別にいいですし",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 912.2,
    "end": 913.2,
    "text": "僕はどちらかといったら",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 913.2,
    "end": 914.2,
    "text": "インデックスも別にいいですし",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 914.2,
    "end": 919.2,
    "text": "インデックスってなんか世の中ではいいって言われてるけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 919.2,
    "end": 922.2,
    "text": "今銘柄選べるインデックスの中でも",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 922.2,
    "end": 925.2,
    "text": "やっぱり株しかないっていうのが僕はリスクであって",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 925.2,
    "end": 929.2,
    "text": "株だけだからやっぱり確かに500銘柄で分散はされてる",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 929.2,
    "end": 931.2,
    "text": "じゃあどっか個別で1銘柄で",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 931.2,
    "end": 935.2,
    "text": "ここが沈んでしまっても499があるから",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 935.2,
    "end": 938.2,
    "text": "ぶっちゃけ大丈夫っていうのはあると思うんですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 938.2,
    "end": 941.2,
    "text": "でも世界経済株ずっと右肩上がりですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 941.2,
    "end": 943.2,
    "text": "下がるときは全部一緒に下がるんで",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 943.2,
    "end": 946.2,
    "text": "上がったときに下がらないような資産って何なのかって言ったら",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 946.2,
    "end": 948.2,
    "text": "今で言うと債券もそうだし",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 948.2,
    "end": 950.2,
    "text": "ゴールドもそうだと思うし",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 950.2,
    "end": 954.2,
    "text": "ちょっと前だったらゴールドも一緒に株と下がっちゃったんで",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 954.2,
    "end": 957.2,
    "text": "今デジタルゴールドって言われてるようなビットだったりとか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 957.2,
    "end": 961.2,
    "text": "ああいったものを大体資産として持っておくっていうのは",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 961.2,
    "end": 964.2,
    "text": "ちょっとリスクを抑えれるかなと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 964.2,
    "end": 967.2,
    "text": "こういった部分がちゃんと分かった上で",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 967.2,
    "end": 969.2,
    "text": "僕始めるんだったらいいと思うんですよ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 969.2,
    "end": 972.2,
    "text": "NISAでインデックスでもちろんそれも大事",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 972.2,
    "end": 975.2,
    "text": "だけどこういったことがあるんだよっていうことを",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 975.2,
    "end": 980.2,
    "text": "大体の方がやってたらもう増えるっていう風なイメージを持ってるから",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 980.2,
    "end": 983.2,
    "text": "そうじゃないんだよっていうところが分かった上で",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 983.2,
    "end": 985.2,
    "text": "始めるんだったらいいかなと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 985.2,
    "end": 989.2,
    "text": "だから僕さっき言ってたアセットアロケーションの考え方っていうのが",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 989.2,
    "end": 994.2,
    "text": "始めるんだったらちゃんとこれで資産形成するって決めるんだったら",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 994.2,
    "end": 998.2,
    "text": "そこまでは大前提分かっておいた状態でやらないと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 998.2,
    "end": 1001.2,
    "text": "意味がないんじゃないかなとは思ってます",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1001.2,
    "end": 1002.2,
    "text": "なるほど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1002.2,
    "end": 1007.2,
    "text": "結局若い子も怖くてできませんね今の話聞いてると",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1007.2,
    "end": 1009.2,
    "text": "どうですかそれ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1009.2,
    "end": 1013.2,
    "text": "だからこそ最初は5000円からスタートする",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1013.2,
    "end": 1017.2,
    "text": "今の渡辺さんのおっしゃることって大正解なんです",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1017.2,
    "end": 1020.2,
    "text": "お金を結構持ってる人はそうやって分散をするってことに",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1020.2,
    "end": 1022.2,
    "text": "チャレンジできると思うんですけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1022.2,
    "end": 1024.2,
    "text": "まずそのレベルに達してない人はまずは",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1024.2,
    "end": 1027.2,
    "text": "なくなってもいいお金の中でチャレンジするっていうのが大事",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1027.2,
    "end": 1030.2,
    "text": "だから僕は飲み会1回分の5000円からスタートして",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1030.2,
    "end": 1031.2,
    "text": "それが半分になるかもしれないけど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1032.2,
    "end": 1035.2,
    "text": "飲み会1回なくなった分ぐらいで済むわけじゃないですか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1035.2,
    "end": 1038.2,
    "text": "なのでそういうところから始めていくのがいいかなと",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1038.2,
    "end": 1042.2,
    "text": "なのであとは機械損失っていってやらないことが一番喪失だと僕は思うんで",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1042.2,
    "end": 1045.2,
    "text": "始めるところからちょっとずつ練習していけばいいんじゃないかなと思ってます",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1045.2,
    "end": 1046.2,
    "text": "なるほど",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1046.2,
    "end": 1049.2,
    "text": "ちょっとねまだまだ話足りないんですけども",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1049.2,
    "end": 1051.2,
    "text": "まずは今日のまとめとしてはですね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1051.2,
    "end": 1056.2,
    "text": "ちょっとした奨学からまずは兄さん始めろこれでいいですか",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1056.2,
    "end": 1057.2,
    "text": "僕はそう思います",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1057.2,
    "end": 1058.2,
    "text": "分かりました",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1058.2,
    "end": 1060.2,
    "text": "じゃあまずはねちょっと見てる皆さんね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1060.2,
    "end": 1061.2,
    "text": "結局何やったらいいのになってると思うんですよ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1061.2,
    "end": 1063.2,
    "text": "どうかなどうかな",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1063.2,
    "end": 1064.2,
    "text": "まず佐久間さんを信じて",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1064.2,
    "end": 1065.2,
    "text": "僕は信じてないぞ",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1065.2,
    "end": 1066.2,
    "text": "僕も信じていきましょう",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1066.2,
    "end": 1068.2,
    "text": "飲み会で兄さん始めましょう",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1068.2,
    "end": 1070.2,
    "text": "まずは始めるところで",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1070.2,
    "end": 1072.2,
    "text": "飲みに行ったほうがいいと思うけどな",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1072.2,
    "end": 1074.2,
    "text": "飲みには行ったほうがいいですね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1074.2,
    "end": 1075.2,
    "text": "それちょっとまた次週ね",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1075.2,
    "end": 1077.2,
    "text": "兄さんもやるどっちもやりましょう",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1077.2,
    "end": 1080.2,
    "text": "ということで次週もこのメンバーでお届けします",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1080.2,
    "end": 1089.2,
    "text": "来週のテーマは美容師はセンス投資もセンス月が資産に変わる瞬間というテーマでお届けしていきたいと思います",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1089.2,
    "end": 1090.2,
    "text": "それでは次週もまたご覧ください",
    "source_file": "#2 CAM 1 01.mp4"
  },
  {
    "start": 1091.2,
    "end": 1100.2,
    "text": "ちょっと慣れてきましたね",
    "source_file": "#2 CAM 1 01.mp4"
  }
]