[
  {
    "start": 0.0,
    "end": 29.98,
    "text": "ご視聴ありがとうございました",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 30.0,
    "end": 33.28,
    "text": "人気で居続けられる人ってごくわずかだと思っていて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 33.28,
    "end": 37.42,
    "text": "順番的に言うと僕おすすめなのがやっぱり不動産ですかね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 37.42,
    "end": 41.04,
    "text": "お金を借り入れできるっていうのってめちゃくちゃ強いと思ってて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 41.04,
    "end": 43.7,
    "text": "学ぼうっていう意思を持っていくかいかないかの",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 43.7,
    "end": 46.56,
    "text": "今回勉強になる美容師さん多いと思いますが",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 46.56,
    "end": 50.3,
    "text": "意外とお金の話ってね美容師の段取りに来なかったと思うんで",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 58.6,
    "end": 59.94,
    "text": "はい皆さん今週も",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 59.94,
    "end": 60.94,
    "text": "よろしくお願いします",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 60.94,
    "end": 65.5,
    "text": "なんとこのメンバーでのラストテーマになります",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 65.5,
    "end": 66.7,
    "text": "それではこちら",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 66.7,
    "end": 69.38,
    "text": "技術を磨くようにお金を育てろ",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 69.38,
    "end": 71.52,
    "text": "未来をデザインするマネーリテラシー",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 71.52,
    "end": 73.78,
    "text": "というテーマでお送りしたいと思います",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 73.78,
    "end": 78.44,
    "text": "美容師が将来資産を増やすにはどんな人生設計を描けばいいのか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 78.44,
    "end": 83.6,
    "text": "具体的なライフスタイルも含めた設計プランをお伺いしたいと思うんですが",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 83.6,
    "end": 87.42,
    "text": "ちょっと一番まずお若いであろう鎌田くんから",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 87.42,
    "end": 89.42,
    "text": "ズバリ聞いていいですか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 89.42,
    "end": 91.16,
    "text": "ズバリ",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 91.16,
    "end": 92.56,
    "text": "難しいっすね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 92.56,
    "end": 94.44,
    "text": "難しいっすよ",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 94.44,
    "end": 99.24,
    "text": "ただここ3週の話全部聞いて思ったんですけど",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 99.24,
    "end": 103.6,
    "text": "まず美容師としては絶対お客様に選ばれる能力がなきゃいけないんで",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 103.6,
    "end": 106.02,
    "text": "まずはそれを頑張りましょうね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 106.02,
    "end": 112.2,
    "text": "で積み立ては必ず小学でずっと長く長期でやり続けておくべきだと思う",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 112.2,
    "end": 118.48,
    "text": "僕が思うのはやっぱ美容師さんってずっと人気でい続けられる人ってごくわずかだと思っていて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 118.48,
    "end": 119.4,
    "text": "多分本当に人気がある人が多いと思うので",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 119.42,
    "end": 120.74,
    "text": "一握りだと思うんですよ",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 120.74,
    "end": 124.02,
    "text": "それを目指すなら目指すならめっちゃ頑張る自分に投資するでいいと思うんですけど",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 124.02,
    "end": 125.46,
    "text": "そうじゃない場合は",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 125.46,
    "end": 128.16,
    "text": "チンプリンそういう資産っていうものをちゃんと積み上げていって",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 128.16,
    "end": 132.58,
    "text": "自分がこう市場価値がなくなっていったらすごい言い方きつくなっちゃうんですけど",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 132.58,
    "end": 136.86,
    "text": "やっぱこうお客様に大人気美容師じゃなくなってきた時に",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 136.86,
    "end": 143.7,
    "text": "その資産運用は今まで積み立てたものを使って出展するなり独立するなり別のビジネスやるなりみたいな",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 143.7,
    "end": 146.88,
    "text": "っていうのも一個の手なんじゃないかなみたいな",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 146.88,
    "end": 148.88,
    "text": "そこに気づく能力が結局ないと",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 149.42,
    "end": 150.68,
    "text": "何に投資しても結局意味ない",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 150.68,
    "end": 153.8,
    "text": "例えば佐久間さんに新美顔を磨くって観点がなければ",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 153.8,
    "end": 155.78,
    "text": "ただヴィンテージ買ってる人になるじゃないですか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 155.78,
    "end": 157.78,
    "text": "ってなったら意味ないよねってなるんで",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 157.78,
    "end": 160.74,
    "text": "昔の僕はそうだったんだなと思ったんだけど",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 160.74,
    "end": 166.0,
    "text": "そういう意味では本当に一番今自分と会社に投資してるっていう",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 166.0,
    "end": 168.54,
    "text": "そうですね自分と会社に投資して",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 168.54,
    "end": 171.98,
    "text": "僕多分参考にならないと思うんで僕の事例は",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 171.98,
    "end": 177.04,
    "text": "でもやっぱりこのマーケットの広さをやっぱり見た方がいいなと思いますね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 177.04,
    "end": 178.36,
    "text": "どの観点から言っても",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 178.36,
    "end": 179.36,
    "text": "なんで",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 179.36,
    "end": 182.36,
    "text": "今僕は英語と海外でいるっていう生活",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 182.36,
    "end": 184.36,
    "text": "そこにサバイバルみたいなもんなんで",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 184.36,
    "end": 188.36,
    "text": "そこで生きる生活みたいな風に投資してるって感じですけど僕は今",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 188.36,
    "end": 189.72,
    "text": "そんなことなんでじゃあちょっと",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 189.72,
    "end": 190.76,
    "text": "じゅんさんもね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 190.76,
    "end": 192.96,
    "text": "ある種一番年上枠として",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 192.96,
    "end": 194.96,
    "text": "そうですね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 194.96,
    "end": 196.96,
    "text": "50年どうですか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 196.96,
    "end": 202.1,
    "text": "若いうちはやっぱり自分に自信をつけれるような美容師さんなんで",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 202.1,
    "end": 205.76,
    "text": "やっぱりそういうセンスとか技術磨いてほしいと思いますし",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 205.76,
    "end": 209.36,
    "text": "順番的に言うと僕オススメなのはやっぱり不動産ですかね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 209.36,
    "end": 211.36,
    "text": "具体的に",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 211.36,
    "end": 219.36,
    "text": "やっぱり僕の友達でやっぱ20歳25くらいで買ってて35の時にはもうローン10年以上払い終わってるよっていうやつがいて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 219.36,
    "end": 224.36,
    "text": "家とか物件って下がんないからだいぶ優位性あるじゃないですか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 224.36,
    "end": 228.36,
    "text": "独立目指してる人とかフリーランスやりたい人っているかもしれないけど",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 228.36,
    "end": 233.36,
    "text": "お勤めの時とかじゃないと信用がないんで買えないんですよね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 233.36,
    "end": 236.36,
    "text": "僕独立して自分で苦悩したことありますけど",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 236.36,
    "end": 238.36,
    "text": "いくら自分お客さんいて稼いでるんだって言ってもね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 238.36,
    "end": 239.16,
    "text": "僕は自分で苦悩したことありますけどいくら自分お客さんいて稼いでるんだって言ってもね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 239.16,
    "end": 240.16,
    "text": "僕は自分で苦悩したことありますけどいくら自分お客さんいて稼いでるんだって言っても",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 240.16,
    "end": 241.16,
    "text": "要はフリーランスと同じ扱いですよね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 241.16,
    "end": 244.16,
    "text": "個人事業主の信用信頼ないので",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 244.16,
    "end": 249.16,
    "text": "そういった意味では勤めてる期間で自分の信用信頼を得て",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 249.16,
    "end": 251.16,
    "text": "所得税減税とかもありますから",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 251.16,
    "end": 256.16,
    "text": "そういうなんていうのディフェンスの方のマネーリテラシーもちゃんと勉強しながら",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 256.16,
    "end": 260.16,
    "text": "投資のことも考えながらやったらいいんじゃないかなって",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 260.16,
    "end": 265.16,
    "text": "結局はかっこいいとか可愛いとかイケてるとかイケてないで決めて欲しいですね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 265.16,
    "end": 267.16,
    "text": "美容師だけにね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 267.16,
    "end": 268.16,
    "text": "そこを磨いてほしい",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 268.16,
    "end": 269.52,
    "text": "バッチリやっちゃってるからな",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 269.52,
    "end": 272.04,
    "text": "そうやって言っておくよくないんだよな",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 272.04,
    "end": 275.86,
    "text": "お金を持ってるっていうことでね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 275.86,
    "end": 278.6,
    "text": "渡辺さんいかがですか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 278.6,
    "end": 280.44,
    "text": "僕もそうですね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 280.44,
    "end": 285.1,
    "text": "やっぱり最初の段階20代の前半は",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 285.1,
    "end": 287.86,
    "text": "やっぱり自分の技術磨いていただいて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 287.86,
    "end": 291.36,
    "text": "とにかく売り上げを上げていくっていうのに",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 291.36,
    "end": 294.06,
    "text": "注力していった方がいいのかなっていうのはあって",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 294.06,
    "end": 296.1,
    "text": "じゅんさん言ってたように信用力って",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 296.1,
    "end": 297.94,
    "text": "めっちゃ僕も大事かなと思ってて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 297.94,
    "end": 300.22,
    "text": "自分の自己資金で20代なんか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 300.22,
    "end": 302.28,
    "text": "ぶっちゃけないわけじゃないですか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 302.28,
    "end": 303.24,
    "text": "貯めれないし",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 303.24,
    "end": 305.0,
    "text": "でもこの信用力があって",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 305.0,
    "end": 307.04,
    "text": "お金を借り入れできるっていうのって",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 307.04,
    "end": 308.24,
    "text": "めちゃくちゃ強いと思ってて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 308.24,
    "end": 310.4,
    "text": "借り入れできればできるほど",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 310.4,
    "end": 312.96,
    "text": "資産運用の幅も広がるし",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 312.96,
    "end": 314.36,
    "text": "不動産もできるし",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 314.36,
    "end": 315.88,
    "text": "例えば出店もできるし",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 315.88,
    "end": 317.48,
    "text": "ってやっぱりなってくるから",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 317.48,
    "end": 321.26,
    "text": "今の時代目先のお金みたいなんで",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 321.26,
    "end": 322.52,
    "text": "結構やられてる方",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 322.52,
    "end": 324.82,
    "text": "これ敵に回す人多いかもしれないんですけど",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 324.82,
    "end": 326.54,
    "text": "それは多いかなと",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 326.54,
    "end": 327.9,
    "text": "そうすると",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 327.9,
    "end": 330.86,
    "text": "後々自分の中で首絞める方が",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 330.86,
    "end": 333.46,
    "text": "これから増えてくるんじゃないかなっていう",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 333.46,
    "end": 335.32,
    "text": "めちゃくちゃいいこと言ってくれてるわけなんですよ",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 335.32,
    "end": 339.06,
    "text": "だからまずはやっぱりちゃんとお勤めして",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 339.06,
    "end": 342.06,
    "text": "信用力がある美容師さんが",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 342.06,
    "end": 344.78,
    "text": "これからは僕は生き残ってくるんじゃないかな",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 344.78,
    "end": 345.86,
    "text": "と思ってて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 345.86,
    "end": 346.66,
    "text": "その中でね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 346.66,
    "end": 349.1,
    "text": "やっぱちょっと守られてる範囲もあるし",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 349.1,
    "end": 352.5,
    "text": "いわゆる世間一般的に認められてる範囲の中で",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 352.5,
    "end": 354.36,
    "text": "資産形成取り入れていって",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 354.36,
    "end": 356.22,
    "text": "僕はどちらかと言ったら",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 356.22,
    "end": 357.9,
    "text": "生涯美容師を",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 357.9,
    "end": 360.52,
    "text": "できる人がいっぱいいた方がいいと思うし",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 360.52,
    "end": 362.32,
    "text": "そういった時にやっぱりこうね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 362.32,
    "end": 365.52,
    "text": "若い時から少しずつ資産形成していって",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 365.52,
    "end": 368.44,
    "text": "僕で言うと投資信託で分散投資をやっていく",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 368.44,
    "end": 369.6,
    "text": "奨学でやっていったら",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 369.6,
    "end": 372.28,
    "text": "例えばそれが30歳からやっていって",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 372.28,
    "end": 374.1,
    "text": "60代ぐらいになった時に",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 374.1,
    "end": 376.28,
    "text": "多分売り上げのパフォーマンス落ちると思うので",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 376.28,
    "end": 380.02,
    "text": "その時にじゃあ30年やった資産形成のところから",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 380.02,
    "end": 384.14,
    "text": "自分の生活範囲のやつを取り崩していったりとかすれば",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 384.14,
    "end": 387.48,
    "text": "いわゆる安心できるわけじゃないですか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 387.48,
    "end": 387.86,
    "text": "そういった時にやっぱり",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 387.9,
    "end": 392.28,
    "text": "そういった部分で活用していったらいいんじゃないかなと思っているので",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 392.28,
    "end": 395.36,
    "text": "まずは一生懸命働いて信用力",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 395.36,
    "end": 397.74,
    "text": "僕は身につけた方がいいんじゃないかなっていうのが",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 397.74,
    "end": 399.36,
    "text": "正論でしかないですね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 399.36,
    "end": 401.02,
    "text": "本当ね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 401.02,
    "end": 403.1,
    "text": "ちょっと最後先生",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 403.1,
    "end": 405.66,
    "text": "ありがとうございます",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 405.66,
    "end": 411.86,
    "text": "僕はもうズバリ若いうちから投資する一番のメリットっていうのは",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 411.86,
    "end": 413.2,
    "text": "成長の福利",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 413.2,
    "end": 416.28,
    "text": "福利って言葉をすごく大事にして欲しいと思ってるんですね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 416.28,
    "end": 417.9,
    "text": "最初のうち数年はちっちゃいけど",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 417.9,
    "end": 420.02,
    "text": "何十年になるとでかくなっていくんで",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 420.02,
    "end": 424.32,
    "text": "その福利を活用できるのが若いうちから資産形成だったり",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 424.32,
    "end": 426.14,
    "text": "投資をするメリットだと思うんですよ",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 426.14,
    "end": 428.02,
    "text": "なのでこれが一番のメリットだと思ってます",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 428.02,
    "end": 432.74,
    "text": "その上でたくさん稼ぐのが難しい時代に入ってきたなって僕は思ってて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 432.74,
    "end": 433.78,
    "text": "なぜかというと",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 433.78,
    "end": 436.52,
    "text": "日本もようやくインフレが始まってきて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 436.52,
    "end": 437.94,
    "text": "コンビニ行くとね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 437.94,
    "end": 441.14,
    "text": "ガム1個100円で買えたのが180円するんだとか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 441.14,
    "end": 443.7,
    "text": "パップラーメンも300円近くするじゃんとか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 443.7,
    "end": 447.7,
    "text": "要は買ったの単価よりも物のインフレの方がいっちゃってるわけですよ",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 447.9,
    "end": 450.66,
    "text": "じゃあ美容室も上げればいいじゃんと思うんだけど",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 450.66,
    "end": 455.66,
    "text": "でも美容室って残念ながら信号機の数以上に存在しちゃってるから",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 455.66,
    "end": 458.32,
    "text": "じゃあ自分の売ってるところ値上げしちゃうと",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 458.32,
    "end": 462.36,
    "text": "じゃあ自分の予算に合うところに変えようってなっちゃうんですね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 462.36,
    "end": 468.78,
    "text": "なので賢く使うってところにぜひ皆さんは意識していただきたいと思ってるんですよ",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 468.78,
    "end": 472.32,
    "text": "賢く使うって何なのかっていうのが僕は投資だと思ってて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 472.32,
    "end": 474.82,
    "text": "その投資って大きく僕5つあると思うんですよね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 474.82,
    "end": 475.66,
    "text": "5スター",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 475.66,
    "end": 476.66,
    "text": "さすが",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 476.66,
    "end": 477.66,
    "text": "そこも5スター",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 477.9,
    "end": 479.28,
    "text": "そこにもつながるみたいなね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 479.28,
    "end": 482.98,
    "text": "1つ目の欲しいで言うと今渡辺さん言われたみたいな",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 482.98,
    "end": 485.6,
    "text": "社会投資ってことを意識していただきたいと思うんですよ",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 485.6,
    "end": 489.96,
    "text": "自分の信用力を高めるっていうのって非常に投資になりますよね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 489.96,
    "end": 497.16,
    "text": "例えばクレジットカードとか高熱費の支払いを遅延すると自分の信用が落ちてるから",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 497.16,
    "end": 502.32,
    "text": "じゃあ自分さんみたいに家を買うときにそこに買えない人になっちゃうとダメだと思いますし",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 502.32,
    "end": 506.06,
    "text": "あとは結構意識してほしいのが自分自分だけじゃなくて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 506.06,
    "end": 510.66,
    "text": "やっぱり所属してる会社とかサロンに対してどう貢献するかっていうのも",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 510.66,
    "end": 513.02,
    "text": "僕はすごい社会投資になると思ってて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 513.02,
    "end": 517.12,
    "text": "周りが佐久間さんのためだったらって言って味方になってくれるのも投資じゃないですか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 517.12,
    "end": 518.66,
    "text": "要は人徳ですよね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 518.66,
    "end": 520.38,
    "text": "これも投資になると思いますし",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 520.38,
    "end": 524.04,
    "text": "あとはSNSに対する努力とかも",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 524.04,
    "end": 527.76,
    "text": "ヒットしないからやめちゃうとなるともう成長が止まっちゃうと思うんですけど",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 527.76,
    "end": 529.04,
    "text": "やり続けることでね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 529.04,
    "end": 533.56,
    "text": "またそれも新しい何かバズるものが出た時にうまく乗れるかもしれないし",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 533.56,
    "end": 536.04,
    "text": "まず1つ目は社会投資ってのを意識するのがいいんじゃないかなと",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 536.06,
    "end": 541.06,
    "text": "2つ目は金融投資にちょっとずつ始めていくっていうのは",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 541.06,
    "end": 545.06,
    "text": "今のうちからニュースを日々チェックするんでやるべきだと思うんですよ",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 545.06,
    "end": 548.06,
    "text": "だんだんそうやっていでこに伸ばしていったり",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 548.06,
    "end": 551.06,
    "text": "保険型の投資にしていったりとか不動産っていう風に",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 551.06,
    "end": 553.06,
    "text": "ステップアップしていくっていうのが大事かなと",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 553.06,
    "end": 557.06,
    "text": "3つ目は現物投資で自分の好きなものにも投資していく",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 557.06,
    "end": 559.06,
    "text": "例えばじゃあ物を買う時にバッグ欲しいな",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 559.06,
    "end": 563.06,
    "text": "いつもこのブランドだけどエルメスの中だったら安い方だけど",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 563.06,
    "end": 565.06,
    "text": "このやつ選んでみようとか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 565.06,
    "end": 566.06,
    "text": "そのちょっとね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 566.06,
    "end": 569.06,
    "text": "現物と言われるものに触れるってこともすごくいいと思いますし",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 569.06,
    "end": 573.06,
    "text": "結果的にそれがね価値が上がることにつながるんじゃないかなと",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 573.06,
    "end": 576.06,
    "text": "4つ目は会社やってる人は事業投資とか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 576.06,
    "end": 580.06,
    "text": "あと美容師のみんなでも自分のハサミに投資したりとか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 580.06,
    "end": 584.06,
    "text": "あとはヘアキャンプさんに投資していろんな技術学ぶっていうのも大事かなと",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 584.06,
    "end": 586.06,
    "text": "最後が自己投資",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 586.06,
    "end": 588.06,
    "text": "自己投資は僕本当裏切らないと思ってて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 588.06,
    "end": 590.06,
    "text": "自己投資ってどんなのがあるかっていった時に",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 590.06,
    "end": 594.06,
    "text": "例えば体作りトレーニングしていくっていうのも",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 594.06,
    "end": 595.06,
    "text": "筋肉もね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 595.06,
    "end": 596.06,
    "text": "大事だよね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 596.06,
    "end": 598.06,
    "text": "1ヶ月だけ集中してやったところで",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 598.06,
    "end": 600.06,
    "text": "すぐ落ちちゃうわけで",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 600.06,
    "end": 602.06,
    "text": "やり続けるから筋トレも",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 602.06,
    "end": 604.06,
    "text": "ふくりでね筋肉がついていくわけだし",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 604.06,
    "end": 606.06,
    "text": "体力がつくわけじゃないですか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 606.06,
    "end": 609.06,
    "text": "例えばアシスタントの頃は朝早く来て練習して",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 609.06,
    "end": 611.06,
    "text": "夜遅くまでやったり休みの日もやってたのに",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 611.06,
    "end": 614.06,
    "text": "スタイリストデビューした瞬間にねやんなくなる人結構多いじゃないですか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 614.06,
    "end": 617.06,
    "text": "内原さんが何でここまでずっと活躍してる美容師かって言ったら",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 617.06,
    "end": 619.06,
    "text": "やり続けられてるし",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 619.06,
    "end": 622.06,
    "text": "JHAとかねああいうショーにずっとチャレンジし続ける",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 622.06,
    "end": 625.06,
    "text": "ストイックな人生を続けられてるからだと思うんで",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 625.06,
    "end": 628.06,
    "text": "そういう自分の未来につながるような投資を",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 628.06,
    "end": 631.06,
    "text": "自己投資をするってことは大事なんじゃないかなって思うんですよね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 631.06,
    "end": 634.06,
    "text": "なのでこの5つの投資っていうのを意識しながら",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 634.06,
    "end": 638.06,
    "text": "自分の未来を自分でデザインできるようになったらいいんじゃないかなと思うんですけど",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 638.06,
    "end": 639.06,
    "text": "内原さんいかがでしょう",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 639.06,
    "end": 643.06,
    "text": "いやもう別日に講習受けます",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 643.06,
    "end": 644.06,
    "text": "逆に気になるんですけど",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 644.06,
    "end": 647.06,
    "text": "坂本さんがもう浪費って何ですか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 647.06,
    "end": 651.06,
    "text": "結局浪費って人によって違うなって思ってて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 651.06,
    "end": 654.06,
    "text": "例えばジュンさんにとっては意味があるという飲み会って",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 654.06,
    "end": 655.06,
    "text": "人にとっては浪費だと思うとか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 655.06,
    "end": 658.06,
    "text": "でもその一つのことから学ぼうっていう",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 658.06,
    "end": 661.06,
    "text": "意思を持って行くか行かないかのその意識の使って大きいじゃん",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 661.06,
    "end": 662.06,
    "text": "っていうことですよね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 662.06,
    "end": 666.06,
    "text": "例えばだけどじゃあ夜の六本木から学べる人もいると思うんだよね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 666.06,
    "end": 669.06,
    "text": "学べることもありますよやっぱり",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 669.06,
    "end": 672.06,
    "text": "そういう人もいるだろうし",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 672.06,
    "end": 676.06,
    "text": "っていうことはやっぱりさっき言っていた選んだものから",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 676.06,
    "end": 680.06,
    "text": "それを投資と捉えて自分で気づくことが大事なんだぜ",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 680.06,
    "end": 682.06,
    "text": "それがいわゆる心理眼ってやつだよね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 682.06,
    "end": 684.06,
    "text": "心理眼",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 684.06,
    "end": 690.06,
    "text": "また来たよ",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 690.06,
    "end": 692.06,
    "text": "僕も質問したい",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 692.06,
    "end": 697.06,
    "text": "なんか僕はもうタイプ的にやっぱ欲しいものがある",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 697.06,
    "end": 699.06,
    "text": "いくら稼がなきゃいけないとかこれをやりたい",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 699.06,
    "end": 701.06,
    "text": "そのためにお金作ろう",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 701.06,
    "end": 703.06,
    "text": "もしくはそれに対して融資を受けようとか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 703.06,
    "end": 707.06,
    "text": "そういうのに対してすごくなんかこうエキサイティングできる",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 707.06,
    "end": 711.06,
    "text": "それに対しては一生懸命努力できたりとか動けるわけです行動的に",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 711.06,
    "end": 713.06,
    "text": "だけどやっぱり前の話聞いてると",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 713.06,
    "end": 718.06,
    "text": "やっぱりそれを自分の習慣のようにしていくじゃないですか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 718.06,
    "end": 721.06,
    "text": "身につけていく考え方も含めてですね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 721.06,
    "end": 724.06,
    "text": "それはどう身につけていったらいいんですか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 724.06,
    "end": 727.06,
    "text": "僕は今ジュンさんのおっしゃってる中で答えがあるなと思ってて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 727.06,
    "end": 730.06,
    "text": "欲しいものってつまり欲じゃないですか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 730.06,
    "end": 734.06,
    "text": "欲がないと人って頑張れないと思う",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 734.06,
    "end": 736.06,
    "text": "そうなんですね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 736.06,
    "end": 740.06,
    "text": "そこの欲を持つ意識をすべきだと思ってて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 740.06,
    "end": 742.06,
    "text": "僕も欲がない時代ってあったんですけど",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 742.06,
    "end": 744.06,
    "text": "そうすると頑張んなくなっちゃうんですね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 744.06,
    "end": 745.06,
    "text": "そうなんですよ",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 745.06,
    "end": 747.06,
    "text": "でなんかそれみんなに稼がせたいし",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 747.06,
    "end": 750.06,
    "text": "なんかよくしたいなと思ってやるじゃないですか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 750.06,
    "end": 754.06,
    "text": "やればやるほどみんななんかもういい感じになんか整っていくんですよね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 754.06,
    "end": 755.06,
    "text": "うんうんうん",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 755.06,
    "end": 756.06,
    "text": "満足してっちゃったりして",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 756.06,
    "end": 758.06,
    "text": "そうそうだから逆に推しとかがいる方が頑張れるみたいな",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 758.06,
    "end": 759.06,
    "text": "なるほどですね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 759.06,
    "end": 761.06,
    "text": "感じですよねみんなね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 761.06,
    "end": 765.06,
    "text": "嫌なことでもこうね自己成長のためにやろうって思うのは",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 765.06,
    "end": 768.06,
    "text": "欲があるからなんで僕はやっぱり欲ってすごく大事だと思う",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 768.06,
    "end": 769.06,
    "text": "大事っすよね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 769.06,
    "end": 770.06,
    "text": "それはめちゃくちゃ思う",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 770.06,
    "end": 771.06,
    "text": "ねえ",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 771.06,
    "end": 773.06,
    "text": "欲まみれっすもん僕らって",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 773.06,
    "end": 777.06,
    "text": "だからさやっぱり鎌ちゃんはさ面白い人やなと思うじゃん",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 777.06,
    "end": 780.06,
    "text": "やっぱ欲がある人ってさ面白いなと思うわけよ",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 780.06,
    "end": 781.06,
    "text": "よろしくです",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 781.06,
    "end": 787.06,
    "text": "なんかお金稼ぐの上手な人って自分が脳汁出るポイントがねどこなのか分かってるじゃん",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 787.06,
    "end": 788.06,
    "text": "あーそうですね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 788.06,
    "end": 791.06,
    "text": "で脳汁ポイントが分かってるからそこにはね頑張っちゃうわけですよね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 791.06,
    "end": 792.06,
    "text": "馬車生まれるように",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 792.06,
    "end": 793.06,
    "text": "馬車生まれるように慣れちゃうんですね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 793.06,
    "end": 795.06,
    "text": "キラキラしますよねやっぱりそういう人見てると",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 795.06,
    "end": 796.06,
    "text": "そうですね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 796.06,
    "end": 799.06,
    "text": "なんか応援する人がやっぱり増えてくるっていうのがあるんで",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 799.06,
    "end": 800.06,
    "text": "僕はやっぱりこう人は",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 801.06,
    "end": 803.06,
    "text": "応援したい生き物だと思うので",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 803.06,
    "end": 807.06,
    "text": "やっぱりその欲に対して貪欲にいってる人って",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 807.06,
    "end": 809.06,
    "text": "なんかスポーツとか見ててもそうだと思うんですよ",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 809.06,
    "end": 811.06,
    "text": "野球とかもう大谷とかね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 811.06,
    "end": 816.06,
    "text": "やっぱりあれを応援してても実際僕ら何の得にもなんないじゃないですか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 816.06,
    "end": 818.06,
    "text": "でもああいったものって応援したいじゃないですか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 818.06,
    "end": 819.06,
    "text": "一生懸命頑張ってるから",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 819.06,
    "end": 824.06,
    "text": "だからやっぱり欲を持ってそれに対して全力でいってる人って",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 824.06,
    "end": 827.06,
    "text": "多分応援する人ってめちゃくちゃ増えてくるんじゃないかなと思うので",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 827.06,
    "end": 830.06,
    "text": "その欲はやっぱりかっこいい方の欲ですよね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 830.06,
    "end": 831.06,
    "text": "そうですそうですそうです",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 831.06,
    "end": 833.06,
    "text": "でもダサい欲があるからそこがね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 833.06,
    "end": 835.06,
    "text": "結構神一人なのかもしれないですよね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 838.06,
    "end": 840.06,
    "text": "皆さんちょっと一人ずつ",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 840.06,
    "end": 843.06,
    "text": "ズバリちょっと視聴者へのメッセージ含めて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 843.06,
    "end": 845.06,
    "text": "終わりにしたいなと思うんで",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 845.06,
    "end": 847.06,
    "text": "ちょっと改めて潤さんからお願いしてもいいでしょうか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 847.06,
    "end": 850.06,
    "text": "本当にお金儲けっていうか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 850.06,
    "end": 854.06,
    "text": "勝ちたいとかバズるようなことはしたいんだって",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 854.06,
    "end": 856.06,
    "text": "青汁王子じゃないですけど",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 856.06,
    "end": 860.06,
    "text": "最初からもう売却するための会社を作るとかね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 860.06,
    "end": 863.06,
    "text": "そのぐらいのことを思ってないとできないと思います",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 863.06,
    "end": 864.06,
    "text": "僕は",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 864.06,
    "end": 867.06,
    "text": "であればやっぱり目の前の人とか関わる人と",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 867.06,
    "end": 870.06,
    "text": "いかに楽しい時間を過ごせるかっていうところに",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 870.06,
    "end": 872.06,
    "text": "やっぱり人生ってかかってると思いますから",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 872.06,
    "end": 875.06,
    "text": "そのためにお金が必要なんだと思うんで",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 875.06,
    "end": 878.06,
    "text": "それをやっぱり理解して迎え合うことがいいんじゃないかなって",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 878.06,
    "end": 880.06,
    "text": "本当に思います",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 880.06,
    "end": 882.06,
    "text": "じゃあ佐久間さんお願いします",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 882.06,
    "end": 884.06,
    "text": "僕は皆さんへのメッセージとしては",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 884.06,
    "end": 888.06,
    "text": "意思を持って続けるってことを大事にしてほしいなと思ってるんですよね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 888.06,
    "end": 889.06,
    "text": "うさぎと亀という亀みたいなね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 889.06,
    "end": 891.06,
    "text": "なってほしくて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 891.06,
    "end": 893.06,
    "text": "最近いろんな方とお会いすると",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 893.06,
    "end": 895.06,
    "text": "やっぱりこう会社経営やってる人だったら",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 895.06,
    "end": 897.06,
    "text": "何が次流行りますかねって",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 897.06,
    "end": 899.06,
    "text": "楽して売り上げ上げようとしたりとか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 899.06,
    "end": 903.06,
    "text": "今の美容師の子たち見ると周りがフリーランスになってるからとか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 903.06,
    "end": 906.06,
    "text": "やっぱり自分の人生を結局豊かにしたいな",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 906.06,
    "end": 908.06,
    "text": "自由になりたいなって思うんだったら",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 908.06,
    "end": 910.06,
    "text": "その目標に対して逆算しながら",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 910.06,
    "end": 913.06,
    "text": "コツコツと楽な方を選ばずに",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 913.06,
    "end": 916.06,
    "text": "苦しいと思う方を選び続けて成長していった方が",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 916.06,
    "end": 918.06,
    "text": "結果的には早く豊かになると思ってるんで",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 918.06,
    "end": 921.06,
    "text": "なので学び続けていただきたいですね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 921.06,
    "end": 923.06,
    "text": "そうですね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 923.06,
    "end": 925.06,
    "text": "渡辺さんお願いします",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 925.06,
    "end": 926.06,
    "text": "はい",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 926.06,
    "end": 929.06,
    "text": "正直やっぱりいろんな方々美容師さんだったりとか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 929.06,
    "end": 932.06,
    "text": "いろんなところでお話聞かせてくださいと",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 932.06,
    "end": 935.06,
    "text": "教えてくださいみたいな感じで結構言われることが多くて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 935.06,
    "end": 939.06,
    "text": "だけどほとんどの方って本当に短期的なものしか見てない",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 939.06,
    "end": 941.06,
    "text": "今これでどうやって稼げるんですかと",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 941.06,
    "end": 944.06,
    "text": "これ買ったらいいですかっていうところしかやっぱり見てない",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 944.06,
    "end": 948.06,
    "text": "そうすると後々なったらやっぱりしんどくなってくる",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 948.06,
    "end": 950.06,
    "text": "っていうのもありますし",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 950.06,
    "end": 953.06,
    "text": "目先のものに関してはやっぱり今の技術だったりとか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 953.06,
    "end": 957.06,
    "text": "目先のお客様を満足させるように頑張っていただいて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 957.06,
    "end": 959.06,
    "text": "やっぱり運用ってなってくるのは",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 959.06,
    "end": 963.06,
    "text": "やっぱり長期で積み立てで分散やっていくことによって",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 963.06,
    "end": 966.06,
    "text": "皆さんの人生って絶対変わってくると僕は思ってるので",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 966.06,
    "end": 971.06,
    "text": "そういった部分でしっかりとリテラシーを高めたい方に関しては",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 971.06,
    "end": 975.06,
    "text": "僕に対して質問来ていただいても全然結構ですので",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 975.06,
    "end": 978.06,
    "text": "皆さんとより学びながら",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 978.06,
    "end": 980.06,
    "text": "成長していければと僕も思ってますので",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 980.06,
    "end": 982.06,
    "text": "今回ありがとうございました",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 982.06,
    "end": 984.06,
    "text": "では最後鎌田さんお願いします",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 984.06,
    "end": 986.06,
    "text": "まず美容師としてだと",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 986.06,
    "end": 989.06,
    "text": "まずやっぱり稼げる美容師にならなきゃいけない",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 989.06,
    "end": 991.06,
    "text": "稼げるっていう言い方多分あんまり好きじゃないと思うんですけど",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 991.06,
    "end": 994.06,
    "text": "お客様に選ばれる美容師にまずなるっていうのが",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 994.06,
    "end": 996.06,
    "text": "大前提大事だよねって思ってます",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 996.06,
    "end": 1000.06,
    "text": "その後に運用する、選択するなり",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1000.06,
    "end": 1002.06,
    "text": "ヴィンテージのものを買うなり",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1002.06,
    "end": 1005.06,
    "text": "かっこいい道を選ぶなりは別に好きそれぞれでいいと思っていて",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1005.06,
    "end": 1008.06,
    "text": "ただその中で自分に気づく能力があるかどうか",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1008.06,
    "end": 1010.06,
    "text": "多分そっちの方が大事だと思うんで",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1010.06,
    "end": 1012.06,
    "text": "そこを常に考えながら生きていけば",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1012.06,
    "end": 1015.06,
    "text": "ぶっちゃけ選んだ道が正解になると思うんで",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1015.06,
    "end": 1018.06,
    "text": "いいんじゃないかなって僕は思いますね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1018.06,
    "end": 1020.06,
    "text": "僕も夜飲んでるキャラみたいな感じで",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1020.06,
    "end": 1022.06,
    "text": "今日ここまで進行してますけども",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1022.06,
    "end": 1025.06,
    "text": "僕ロサンゼルス行ってから夜一切飲まなくなったんですよ",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1025.06,
    "end": 1027.06,
    "text": "朝めっちゃ早く起きるようになって",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1027.06,
    "end": 1030.06,
    "text": "毎日朝ジム行って毎日英語勉強して",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1030.06,
    "end": 1032.06,
    "text": "そっから仕事してって",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1032.06,
    "end": 1034.06,
    "text": "それも多分自分にとっての自己投資だと思ってますし",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1034.06,
    "end": 1036.06,
    "text": "夜ももちろんたくさん飲んでたんですけど",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1036.06,
    "end": 1038.06,
    "text": "それはそれで僕も気づくことがたくさんあったんですよ",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1038.06,
    "end": 1041.06,
    "text": "いい人も悪いものもたくさん見ましたので",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1041.06,
    "end": 1042.06,
    "text": "そんな感じでですね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1042.06,
    "end": 1044.06,
    "text": "自分が選んだものを正解にできる",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1044.06,
    "end": 1047.06,
    "text": "自分を身につけられればいいんじゃないかなと思います",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1047.06,
    "end": 1049.06,
    "text": "以上はこれで僕からのメッセージになります",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1049.06,
    "end": 1051.06,
    "text": "ありがとうございました",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1051.06,
    "end": 1053.06,
    "text": "いやでも本当今回",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1053.06,
    "end": 1055.06,
    "text": "結構勉強になる美容師さん多いと思います",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1055.06,
    "end": 1057.06,
    "text": "意外とお金の話ってね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1057.06,
    "end": 1059.06,
    "text": "そんな美容師の番組じゃなかったと思うので",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1059.06,
    "end": 1061.06,
    "text": "渡辺君ありがとうございました",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1061.06,
    "end": 1062.06,
    "text": "ありがとうございました",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1062.06,
    "end": 1063.06,
    "text": "ということでね",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1063.06,
    "end": 1065.06,
    "text": "今回ご視聴いただきありがとうございました",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1065.06,
    "end": 1067.06,
    "text": "次回は新たなメンバーで",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1067.06,
    "end": 1068.06,
    "text": "宿毛矯正",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1068.06,
    "end": 1070.06,
    "text": "についてお送りしたいと思います",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1070.06,
    "end": 1072.06,
    "text": "それではお楽しみに",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1072.06,
    "end": 1073.06,
    "text": "それではまた",
    "source_file": "#20_fix.mp4"
  },
  {
    "start": 1098.06,
    "end": 1099.06,
    "text": "バイバイ",
    "source_file": "#20_fix.mp4"
  },
