[
  {
    "start": 0.0,
    "end": 29.98,
    "text": "ご視聴ありがとうございました",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 30.0,
    "end": 59.98,
    "text": "次回予告",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 59.98,
    "end": 61.14,
    "text": "今週もよろしくお願いします",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 61.14,
    "end": 61.98,
    "text": "よろしくお願いします",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 61.98,
    "end": 65.36,
    "text": "週刊ヘアキャンプ今週のテーマはこちら",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 65.36,
    "end": 71.16,
    "text": "業種はセンス、投資もセンス、好きか資産に変わる瞬間ということで",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 71.16,
    "end": 77.16,
    "text": "ゲストの皆さんの趣味が投資につながったという具体的なエピソードをお伺いしていきたいと思うんですが",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 77.16,
    "end": 82.2,
    "text": "先週ちょっといろいろ話もねかなり割れたかなと思うんですが",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 82.2,
    "end": 86.38,
    "text": "ちょっと一番話足りなかったであろうをちょっとじゅんさんから",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 86.38,
    "end": 89.78,
    "text": "そうですねやっぱり2位差がね大事ですよね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 89.78,
    "end": 95.02,
    "text": "まず大事だよねっていうね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 95.02,
    "end": 97.6,
    "text": "美容師さんなんで楽しみながらね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 97.6,
    "end": 101.36,
    "text": "もちろん技術とかセキュリティとか真面目な仕事の話もありますけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 101.36,
    "end": 106.58,
    "text": "やっぱりカルチャー的なものこれに触れてほしいなと僕は思っていまして",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 106.58,
    "end": 113.04,
    "text": "総軍だったらすごい数の時間とレコードを買って音楽リテラシーを高めたりして",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 113.04,
    "end": 116.7,
    "text": "DJのお仕事とかしてたりとかあるわけじゃないですか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 116.7,
    "end": 118.7,
    "text": "僕らの世代だと",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 118.7,
    "end": 119.76,
    "text": "一番最初にそういうのを",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 119.76,
    "end": 121.7,
    "text": "感じたのは古着ですね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 121.7,
    "end": 124.7,
    "text": "スニーカーだったりとかあとゴローズとか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 124.7,
    "end": 128.32,
    "text": "ポケカーじゃないですけど我々の世代だとビックリマンシールとかなんですよ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 128.32,
    "end": 133.12,
    "text": "僕らの頃って1万円とかでうわあのシールが1万円すんのって",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 133.12,
    "end": 136.88,
    "text": "でもちょっと前も10万円とかだったのに今100万円する時代ですからね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 136.88,
    "end": 139.32,
    "text": "えぇそんな数ですか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 139.32,
    "end": 142.98,
    "text": "そういった趣味をやっぱり楽しみながらですね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 142.98,
    "end": 145.78,
    "text": "美容師さんらしくそういうところでセンスを出してほしい",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 145.78,
    "end": 147.04,
    "text": "噛み付いてる理由としては",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 147.04,
    "end": 148.88,
    "text": "どうせお金を稼ぐんだったら",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 149.76,
    "end": 152.38,
    "text": "かっこよく稼いでほしいなみたいなところがあって",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 152.38,
    "end": 154.7,
    "text": "それがなんか頭がいいというか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 154.7,
    "end": 157.12,
    "text": "なんか古俗な感じであるとか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 157.12,
    "end": 159.5,
    "text": "なんかもう一生お客さんとか髪の毛見てないで",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 159.5,
    "end": 162.0,
    "text": "株式相場ばっか見てるみたいになってしまうと",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 162.0,
    "end": 163.32,
    "text": "それはちょっとやっぱね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 163.32,
    "end": 165.2,
    "text": "つまり兄さんはやっぱダサいっていう",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 165.2,
    "end": 168.44,
    "text": "うんうんうん",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 168.44,
    "end": 169.82,
    "text": "佐久間さんなんか実は",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 169.82,
    "end": 172.62,
    "text": "洋服にかなり突っ込んできた人生だったってことですか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 172.62,
    "end": 176.8,
    "text": "そうっすね僕はもうヴィンテージにすごい投資してきてるんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 176.8,
    "end": 178.66,
    "text": "まあジュンさんおっしゃる通り",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 178.66,
    "end": 179.76,
    "text": "そのお金の",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 179.76,
    "end": 181.7,
    "text": "増える減るだけではなくて",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 181.7,
    "end": 185.18,
    "text": "文化的な自己成長につながる投資ってすごい大事だと思うんですよ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 185.18,
    "end": 187.54,
    "text": "内田さんはレコードに投資されてきて",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 187.54,
    "end": 189.76,
    "text": "レコードだってヴィンテージのレコードって",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 189.76,
    "end": 192.14,
    "text": "多分すごい価格も肯定してるでしょうし",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 192.14,
    "end": 196.16,
    "text": "結果的にねそれが自分の感性を養って",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 196.16,
    "end": 199.04,
    "text": "それがこの自分のアウトプットにつながっていって",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 199.04,
    "end": 201.14,
    "text": "美容師としての幅になってくると思うとね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 201.14,
    "end": 202.26,
    "text": "僕はヴィンテージ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 202.26,
    "end": 204.5,
    "text": "最初は時計から始まってるんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 204.5,
    "end": 205.64,
    "text": "時計先生だもんね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 205.64,
    "end": 207.68,
    "text": "そうですね業界の中で時計先生って言われてるけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 207.68,
    "end": 208.8,
    "text": "時計先生",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 209.76,
    "end": 211.32,
    "text": "ってのも30年ぐらい経ってるんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 211.32,
    "end": 212.7,
    "text": "今でも古臭くない",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 212.7,
    "end": 215.08,
    "text": "みんな多分これ見るとかっこいいって言うんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 215.08,
    "end": 215.7,
    "text": "かっこいい",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 215.7,
    "end": 218.82,
    "text": "あとはこのデニムも80年前のやつなんですよ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 218.82,
    "end": 219.42,
    "text": "ファーストね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 219.42,
    "end": 219.96,
    "text": "はい",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 219.96,
    "end": 221.66,
    "text": "めちゃくちゃコンディションいいよね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 221.66,
    "end": 224.54,
    "text": "やっぱり時代を越えて残るデザインに触れるって",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 224.54,
    "end": 226.56,
    "text": "すごく感性が見分かれるわけですよ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 226.56,
    "end": 229.28,
    "text": "自分の感性を高めてくれて",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 229.28,
    "end": 233.44,
    "text": "自分の出るセンスにもつながるような投資っていうのは",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 233.44,
    "end": 234.42,
    "text": "すごくいいと思うし",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 234.42,
    "end": 237.88,
    "text": "結果的に希少性が高いから価値も上がっていって",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 237.88,
    "end": 239.3,
    "text": "お金も増えてくっていう",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 239.76,
    "end": 241.14,
    "text": "2兆だと思うんですよ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 241.14,
    "end": 242.7,
    "text": "それ最後全部売るってことですか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 242.7,
    "end": 245.9,
    "text": "欲しいものが出た時に買い替えたりはするんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 245.9,
    "end": 248.8,
    "text": "その時に基本的には目利きが僕はもうできちゃってるんで",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 248.8,
    "end": 250.2,
    "text": "プラスになることが多いですね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 250.2,
    "end": 254.54,
    "text": "だいたい時計とかだともう今まで90%以上の勝率で",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 254.54,
    "end": 257.14,
    "text": "え?買った時より高い",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 257.14,
    "end": 259.3,
    "text": "なので好きなものに投資して",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 259.3,
    "end": 263.64,
    "text": "センスを磨きながら自分だけの個性を磨いていって",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 263.64,
    "end": 266.48,
    "text": "強みに変えるみたいなことは意識してやってますね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 266.48,
    "end": 268.64,
    "text": "それ言うと僕素朴な疑問なんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 268.64,
    "end": 269.64,
    "text": "売れるものしか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 269.76,
    "end": 271.3,
    "text": "買わなくなるってことはないんですか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 271.3,
    "end": 274.76,
    "text": "値上がりするだろうで買っちゃうみたいな側面ないんですか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 274.76,
    "end": 275.66,
    "text": "プレネ系のやつね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 275.66,
    "end": 276.58,
    "text": "そうそうそう",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 276.58,
    "end": 279.4,
    "text": "売る前提で買っちゃうという",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 279.4,
    "end": 281.06,
    "text": "やっぱり面白いもんで",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 281.06,
    "end": 283.46,
    "text": "例えば内田さんもこのレコード",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 283.46,
    "end": 285.7,
    "text": "普段俺聞かないけど上がるかもなって言って買うもの",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 285.7,
    "end": 286.9,
    "text": "だいたい外れたりすると思うんですよ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 286.9,
    "end": 290.72,
    "text": "やっぱり自分の守備範囲を超えるものを買うと失敗するんですよ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 290.72,
    "end": 292.74,
    "text": "だから上がるかもしれないなって瞬間に",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 292.74,
    "end": 294.74,
    "text": "もう守備範囲超えちゃってるじゃないですか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 294.74,
    "end": 297.14,
    "text": "だからそういうのは僕は手出さないですね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 297.14,
    "end": 299.28,
    "text": "やっぱり自分の分かってる領域の中で",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 299.76,
    "end": 300.56,
    "text": "ときめくもの",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 300.56,
    "end": 303.84,
    "text": "そこになるべく触れるように",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 303.84,
    "end": 307.02,
    "text": "まず最初は好きからやっぱりちゃんと始まってはいけない",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 307.02,
    "end": 308.44,
    "text": "やっぱり好きこそ物の上手なレッド",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 308.44,
    "end": 311.16,
    "text": "めっちゃ調べるんですか買う前に",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 311.16,
    "end": 312.62,
    "text": "めちゃくちゃ俺は調べるね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 312.62,
    "end": 314.82,
    "text": "AIを3つ駆使して",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 314.82,
    "end": 315.56,
    "text": "3つ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 315.56,
    "end": 318.5,
    "text": "例えばこのシェーヌダンクルの初期コマっていうのが",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 318.5,
    "end": 320.74,
    "text": "いつからいつどういう背景で作られたのか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 320.74,
    "end": 322.16,
    "text": "まず出してくれって言って",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 322.16,
    "end": 323.76,
    "text": "それを買うかも検討していると",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 323.76,
    "end": 325.5,
    "text": "この価格が適正なのかとか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 325.5,
    "end": 327.88,
    "text": "このイエローゴールドがどのくらい希少性が高いのか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 327.88,
    "end": 329.6,
    "text": "っていうのをバーって出してもらった上で",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 329.6,
    "end": 329.74,
    "text": "この価格が適正なのかとか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 329.76,
    "end": 332.12,
    "text": "それをまずあなた自身がファクトチェックしなさいと",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 332.12,
    "end": 333.74,
    "text": "その上でそのファクトチェックを",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 333.74,
    "end": 335.14,
    "text": "他のAIにチェックさせるから",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 335.14,
    "end": 337.2,
    "text": "ファクトチェック用のプロンプトを出力して",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 337.2,
    "end": 338.7,
    "text": "世界に大体何本くらいあるか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 338.7,
    "end": 341.12,
    "text": "調べてるって言ってた",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 341.12,
    "end": 343.94,
    "text": "だからもう何十年くらいやってんのかな",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 343.94,
    "end": 346.88,
    "text": "くらいの知識量とか熱量があるから",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 346.88,
    "end": 349.94,
    "text": "やっぱりねそういうところはね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 349.94,
    "end": 352.06,
    "text": "鎌形くんとか渡辺さんもさっきね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 352.06,
    "end": 353.22,
    "text": "ちょっと控えする話をしてるときに",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 353.22,
    "end": 355.5,
    "text": "少し興味あります?なんてお話ありましたけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 355.5,
    "end": 358.68,
    "text": "どういうところで興味を2人は惹かれたんですか?",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 358.68,
    "end": 361.24,
    "text": "いや僕あの今日本当はですね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 361.24,
    "end": 362.78,
    "text": "佐久間さんにちょっと噛み付いてやろうかな",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 362.78,
    "end": 363.62,
    "text": "と思ってきたんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 363.62,
    "end": 366.64,
    "text": "そもそも僕あのもう結構",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 366.64,
    "end": 369.18,
    "text": "いろいろやっぱ物欲を満たしまくって買ってたんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 369.18,
    "end": 371.12,
    "text": "やっぱその投資的観点は持ってたんですよ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 371.12,
    "end": 372.92,
    "text": "それこそフェラーリだって絶対値上がりするし",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 372.92,
    "end": 376.08,
    "text": "服もビトンカベルエルメスしか買わない",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 376.08,
    "end": 379.2,
    "text": "ファッションの中でも運用効率いいものみたいな",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 379.2,
    "end": 382.62,
    "text": "今思うと結局自分が身につけたいし",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 382.62,
    "end": 385.42,
    "text": "持ってる自分を見せたいから",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 385.42,
    "end": 388.52,
    "text": "資産を売るよっていう単語を使って",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 388.52,
    "end": 391.56,
    "text": "買ってるだけやんみたいな",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 391.56,
    "end": 394.08,
    "text": "それが僕なんかキモいなと思ってたんですよ自分に",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 394.08,
    "end": 396.12,
    "text": "どうしたの?なんか海外ってメンヘラ?",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 396.12,
    "end": 399.86,
    "text": "いやいやそれで海外行く前に全部売り飛ばしたんですよね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 399.86,
    "end": 401.98,
    "text": "もういらないもういいやん",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 401.98,
    "end": 403.56,
    "text": "でもめちゃくちゃわかる",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 403.56,
    "end": 406.7,
    "text": "だから佐久間さんはちゃんと手放して運用して",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 406.7,
    "end": 408.16,
    "text": "税金も払ってってやってた",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 408.16,
    "end": 410.64,
    "text": "僕なんかただのコレクターだから運用してないから",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 410.64,
    "end": 411.08,
    "text": "保有品",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 411.08,
    "end": 415.58,
    "text": "佐久間さんにいや自分が欲しいだけじゃないですかみたいな感じで",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 415.58,
    "end": 417.86,
    "text": "噛み付けしようと思ったんですけど文化人すぎて",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 418.52,
    "end": 420.72,
    "text": "リクしちゃって噛み付けなくなっちゃったんですよ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 420.72,
    "end": 423.16,
    "text": "ちょっと馬鹿にしてんだろ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 423.16,
    "end": 424.8,
    "text": "なるほどみたいな",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 424.8,
    "end": 425.52,
    "text": "だから言ってたじゃないですか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 425.52,
    "end": 427.34,
    "text": "神秘感が磨かれるみたいな",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 427.34,
    "end": 430.16,
    "text": "ヴィンテージとかそういういいものを選べるようになる",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 430.16,
    "end": 433.92,
    "text": "神秘感が身につくからいいんだよって言われると",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 433.92,
    "end": 436.7,
    "text": "その観点で僕は買ってなかったなみたいな",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 436.7,
    "end": 438.2,
    "text": "本当面白いなと思うんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 438.2,
    "end": 440.88,
    "text": "神秘感が磨かれるってのは本当その通りで",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 440.88,
    "end": 444.14,
    "text": "やっぱり最短最速でブランドサロンに認知されるには",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 444.14,
    "end": 445.92,
    "text": "どうしたらいいかって考えるわけですね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 445.92,
    "end": 447.52,
    "text": "そうすると店舗デザイン",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 447.52,
    "end": 448.52,
    "text": "ロゴデザイン",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 448.52,
    "end": 450.9,
    "text": "コンセプトから全部において",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 450.9,
    "end": 455.88,
    "text": "何だったら最上級にかっこいいものでできるのかなって考えるわけよ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 455.88,
    "end": 459.64,
    "text": "もちろんそこには最上級のクリエイティブディレクターとか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 459.64,
    "end": 462.86,
    "text": "内装のデザイナーとかもアサインする必要があるんだけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 462.86,
    "end": 465.64,
    "text": "じゃあこの人たちって本当にセンスがいいんだっけっていう",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 465.64,
    "end": 468.16,
    "text": "自分の神秘感がないとお願いできないじゃないですか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 468.16,
    "end": 472.16,
    "text": "結果的にそういうセンスを常に日頃から磨いていることによって",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 472.16,
    "end": 474.58,
    "text": "結局できたサロンがみんなが来てくれて",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 474.58,
    "end": 476.66,
    "text": "かっこいいって言ってくれたサロンになってるわけだよね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 476.66,
    "end": 478.34,
    "text": "なので自分とっての",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 478.52,
    "end": 481.38,
    "text": "ヴィンテージっていうのは自分の神秘感を磨いて",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 481.38,
    "end": 483.52,
    "text": "結果的に事業としてもつながって",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 483.52,
    "end": 485.52,
    "text": "みんなにとってかっこいいになってるから",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 485.52,
    "end": 487.38,
    "text": "それはすごい良かったかなと思う",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 487.38,
    "end": 488.8,
    "text": "渡辺さんも聞いてたけどどうですか?",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 488.8,
    "end": 490.88,
    "text": "僕も民派な部分があったんで",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 490.88,
    "end": 493.56,
    "text": "それこそスニーカーめちゃくちゃ集めてて",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 493.56,
    "end": 495.96,
    "text": "ちょっと前にイージーブーストとかああいうのとかも",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 495.96,
    "end": 498.18,
    "text": "とりあえず買えるものは全部買って",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 498.18,
    "end": 499.8,
    "text": "僕はかなり民派だったんで",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 499.8,
    "end": 504.54,
    "text": "履くものと売るものっていうのを分けて持ってたんで",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 504.54,
    "end": 508.24,
    "text": "履いててもどうせ価値上がるよね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 508.24,
    "end": 508.5,
    "text": "っていう",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 508.52,
    "end": 510.66,
    "text": "ものは自分で履いて",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 510.66,
    "end": 513.38,
    "text": "ちょっとおしゃれ風に見せてましたし",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 513.38,
    "end": 514.66,
    "text": "これぐらいだったら",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 514.66,
    "end": 517.1,
    "text": "それぐらいの利幅しかないなっていうものは",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 517.1,
    "end": 519.22,
    "text": "全部売りにやっていってたとか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 519.22,
    "end": 521.9,
    "text": "そんなぐらいの僕感じだったんで",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 521.9,
    "end": 523.9,
    "text": "今の話聞いてすごく思ったんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 523.9,
    "end": 525.54,
    "text": "直証記とか出て",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 525.54,
    "end": 528.2,
    "text": "結果としてファッション認知で",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 528.2,
    "end": 530.06,
    "text": "いろんな仕事につながるみたいな",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 530.06,
    "end": 532.98,
    "text": "結果投資にはなったんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 532.98,
    "end": 536.6,
    "text": "ファッションを資産性があるなと思って",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 536.6,
    "end": 538.24,
    "text": "買ったこと一回もなくて",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 538.24,
    "end": 543.18,
    "text": "4人の方は結構これが価値になるなみたいなところが",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 543.18,
    "end": 546.36,
    "text": "結構出発点な感じに聞こえてるんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 546.36,
    "end": 548.06,
    "text": "やっぱそうじゃなきゃいけないんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 548.06,
    "end": 550.8,
    "text": "そのセンスを磨くみたいなことって",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 550.8,
    "end": 552.14,
    "text": "それで言うと",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 552.14,
    "end": 553.76,
    "text": "なんか僕はどっちかっていうと",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 553.76,
    "end": 554.86,
    "text": "そう君側ですよ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 554.86,
    "end": 555.48,
    "text": "側ですか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 555.48,
    "end": 557.06,
    "text": "かっこつけて言うと",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 557.06,
    "end": 559.02,
    "text": "自分が買ったものが高くなっちゃう",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 559.02,
    "end": 563.08,
    "text": "なるほどっすね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 563.08,
    "end": 565.84,
    "text": "そこは考えずやってたけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 565.84,
    "end": 566.86,
    "text": "結果そうなっちゃった",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 566.86,
    "end": 567.96,
    "text": "自分が好きなものがね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 567.96,
    "end": 568.52,
    "text": "マヤもそう",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 568.52,
    "end": 571.18,
    "text": "いつもマヤがいいなーっていう時計がどんどん上がってる",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 571.18,
    "end": 575.44,
    "text": "やっぱり自分が着けてるのみんなかっこいいって言ってくれることが多くて",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 575.44,
    "end": 576.86,
    "text": "例えばデニムの色落ちとかも",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 576.86,
    "end": 579.14,
    "text": "何がかっこいい色落ちなのかって",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 579.14,
    "end": 581.46,
    "text": "結構センスが分かれるんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 581.46,
    "end": 584.34,
    "text": "みんながかっこいいと思う色落ちのものっていうのは",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 584.34,
    "end": 587.42,
    "text": "みんなが欲しがるから価格が担保されるわけですよね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 587.42,
    "end": 590.66,
    "text": "なので僕の場合は欲しいものを買い続けたいんで",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 590.66,
    "end": 592.22,
    "text": "手放すときに価値が下がっちゃうと",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 592.22,
    "end": 594.2,
    "text": "また買えなくなっちゃうのが嫌なんで",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 594.2,
    "end": 597.8,
    "text": "なるべくみんなにとって欲しいものに結果なるような神秘感を見ることが大切です",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 597.96,
    "end": 599.82,
    "text": "やっていこうっていうのが起点であるっていう",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 599.82,
    "end": 602.56,
    "text": "話ちょっとずらしたいんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 602.56,
    "end": 607.3,
    "text": "洋服で言うと今の自分の偏愛から結局出産性になる神秘感大事だよね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 607.3,
    "end": 608.52,
    "text": "みたいな話だと思うんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 608.52,
    "end": 611.04,
    "text": "例えばユンさんおっしゃってた飲み会も",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 611.04,
    "end": 613.46,
    "text": "例えばその概念でいくと",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 613.46,
    "end": 617.68,
    "text": "じゃあメリットのあるやつしか飲みに行かない方がいいよねみたいな若者",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 617.68,
    "end": 619.58,
    "text": "そういうね角度ね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 619.58,
    "end": 623.24,
    "text": "それで言うとどういうふうに捉えてます",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 623.24,
    "end": 625.38,
    "text": "じゃあ飲み会も投資だよねっておっしゃってたと思うんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 625.38,
    "end": 627.94,
    "text": "でもそのメリットデメリットでは考えないって感じですか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 627.94,
    "end": 631.18,
    "text": "僕もその価値があるないとかではないと思うし",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 631.18,
    "end": 636.32,
    "text": "だけどでも単純に今の美容師さんで例えば言うんだったら",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 636.32,
    "end": 639.08,
    "text": "飲み会に関しては今解釈いっぱいあるんでしょうけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 639.08,
    "end": 643.34,
    "text": "なんかある程度ファッションを楽しんでて",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 643.34,
    "end": 645.68,
    "text": "いいものを身につけた方が",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 645.68,
    "end": 648.88,
    "text": "例えばお客様は喜ばれて単価が上がるとかね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 648.88,
    "end": 652.96,
    "text": "そこはもう織り込み済みなんじゃないのかなぐらいは思うかな",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 652.96,
    "end": 656.68,
    "text": "その自分が着てる服が高くリセールするかしないかとかまでは",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 656.68,
    "end": 657.92,
    "text": "僕はもう考えてます",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 657.94,
    "end": 658.64,
    "text": "考えないんだけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 658.64,
    "end": 662.2,
    "text": "でも自分の価値に関しては変わるんじゃないですか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 662.2,
    "end": 664.42,
    "text": "見せ方っていうのは答えが違ったかも",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 664.42,
    "end": 669.72,
    "text": "その資産に変わる瞬間を意識しすぎて",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 669.72,
    "end": 672.8,
    "text": "もういけないんじゃないですかって僕は思った",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 672.8,
    "end": 677.5,
    "text": "それは逆に言うと得意な言い方させてもらうと",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 677.5,
    "end": 678.86,
    "text": "すっごいダサいよね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 678.86,
    "end": 682.1,
    "text": "それが僕もダサいなって思う",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 682.1,
    "end": 684.14,
    "text": "めちゃくちゃダサいよね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 685.14,
    "end": 687.52,
    "text": "だからすごく評判のいい",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 687.94,
    "end": 693.22,
    "text": "ドーナツにやたら長い時間かけて並んでる人もあれよく分かんないなと思ってるんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 693.22,
    "end": 698.18,
    "text": "みんなが人気なものに飛びつくっていう感覚僕は基本的になかったんで",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 698.18,
    "end": 700.6,
    "text": "いいじゃんあれはふわふわでおいしいよ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 700.6,
    "end": 704.06,
    "text": "今これ食べるとすごく",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 704.06,
    "end": 705.7,
    "text": "分かる分かる",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 705.7,
    "end": 707.98,
    "text": "そこに価値を感じて並ぶわけですよね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 707.98,
    "end": 708.9,
    "text": "そうだよね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 708.9,
    "end": 712.28,
    "text": "結局センスを磨くみたいなのが",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 712.28,
    "end": 715.62,
    "text": "本当にどうやったら資産に変わるんですかっていう",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 715.62,
    "end": 717.78,
    "text": "ちょっと心理的な話で言うと",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 717.94,
    "end": 723.06,
    "text": "僕でも思うのは今内原さんが言ったみたいに人気なものに飛びつくっていうのは",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 723.06,
    "end": 725.62,
    "text": "結構ミーハーな人ってそうじゃないですか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 725.62,
    "end": 728.5,
    "text": "それを僕は否定することはしないですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 728.5,
    "end": 730.18,
    "text": "でもまあ多分内原さんもそうだし",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 730.18,
    "end": 732.26,
    "text": "じゅんさんもここにいる皆さんって",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 732.26,
    "end": 735.7,
    "text": "多分流行る前のものを見つけるのが好きで",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 735.7,
    "end": 737.98,
    "text": "それは好きですね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 737.98,
    "end": 739.3,
    "text": "結局それが流行っていく",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 739.3,
    "end": 740.66,
    "text": "さっきじゅんさんが言ったみたいに",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 740.66,
    "end": 744.02,
    "text": "自分が選んだのがみんなかっこいいっていう人気が出るっていう",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 744.02,
    "end": 745.3,
    "text": "そういうものだと思うんですよ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 745.3,
    "end": 747.74,
    "text": "だからクリエイティブの世界もそうだと思ってて",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 747.74,
    "end": 751.82,
    "text": "今じゃあ韓国ヘア流行ってるからそこに乗っかろうってやってるのって",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 751.82,
    "end": 753.82,
    "text": "じゅんさん的に言ったらダサいっていう",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 753.82,
    "end": 756.62,
    "text": "僕も真似は最初の人はいいと思うんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 756.62,
    "end": 759.9,
    "text": "真似を続けてる人はダサいなと思うんですよ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 759.9,
    "end": 761.9,
    "text": "だからやっぱりそこは見つけなきゃいけない",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 761.9,
    "end": 767.98,
    "text": "僕も日本で初めて韓国トレンドヘアに特化したユニっていうサロンを表参道で作ったら",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 767.98,
    "end": 773.58,
    "text": "翌年には表参道原宿の1000サロンのうち600サロンが真似してたんですよ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 773.58,
    "end": 775.34,
    "text": "ずっとみんなそれを真似し続けてて",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 775.34,
    "end": 777.74,
    "text": "それはやっぱりクールじゃないなと思うんですよ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 777.74,
    "end": 780.14,
    "text": "だから次のブーム作ろうって僕も思ってて",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 780.14,
    "end": 783.5,
    "text": "そのブームを作るためには自分の新美顔を磨き続けないと",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 783.5,
    "end": 785.5,
    "text": "そのブームを作れないじゃないですか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 785.5,
    "end": 787.5,
    "text": "新美顔特集したらいいんじゃないですか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 787.5,
    "end": 789.5,
    "text": "確かに",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 789.5,
    "end": 792.5,
    "text": "要はなぞんなよってことでしょ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 792.5,
    "end": 794.5,
    "text": "なぞってんのやっぱダサいよね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 794.5,
    "end": 796.5,
    "text": "最初は手張りって言葉があるみたいに",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 796.5,
    "end": 801.5,
    "text": "カットの技術も大先生の技術もしっかり学んでやっていくのが大事だと思うんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 801.5,
    "end": 803.5,
    "text": "だんだん自己流になってくるじゃないですか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 803.5,
    "end": 805.5,
    "text": "最初のうちはミーハーでちゃんと",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 805.5,
    "end": 807.5,
    "text": "なんでそれがいいのかなって",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 807.74,
    "end": 809.74,
    "text": "ポイントを学びながらも",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 809.74,
    "end": 811.74,
    "text": "でもずっとじゃあ流行ってるから並びに行きますっていう",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 811.74,
    "end": 814.74,
    "text": "週末を休みの日を過ごす続けるのは",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 814.74,
    "end": 816.74,
    "text": "話のネタとしてはいいと思うんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 816.74,
    "end": 818.74,
    "text": "自分のシーンって何なんだっけってところはね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 818.74,
    "end": 820.74,
    "text": "やったほうがいいですよね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 820.74,
    "end": 824.74,
    "text": "でもね流行らないと出産価値は上がらないわけですもんね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 824.74,
    "end": 826.74,
    "text": "そこの難しさもありますよね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 826.74,
    "end": 827.74,
    "text": "そうですね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 827.74,
    "end": 830.74,
    "text": "でもねこう新美顔を磨くっていうのは",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 830.74,
    "end": 833.74,
    "text": "やっぱり少しでもいいものに触れるとか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 833.74,
    "end": 835.74,
    "text": "いい体験をするってことを続ける必要があると思うし",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 835.74,
    "end": 837.74,
    "text": "あと飲み会も僕はそうやって",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 837.74,
    "end": 839.74,
    "text": "すごく大事だと思ってて",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 839.74,
    "end": 841.74,
    "text": "意味のない飲み会にもすごく価値があると思うんですよ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 841.74,
    "end": 844.74,
    "text": "ただ一回行ってみてあまりにも意味がなさすぎたら",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 844.74,
    "end": 846.74,
    "text": "次は考えますけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 846.74,
    "end": 848.74,
    "text": "でも先輩たちとかと行く中で",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 848.74,
    "end": 850.74,
    "text": "普段仲良くない先輩だとしても",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 850.74,
    "end": 854.74,
    "text": "その先輩がどんなことにこだわりを持ってやってるのか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 854.74,
    "end": 857.74,
    "text": "そこを行く側も引き出す力を持ってれば",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 857.74,
    "end": 860.74,
    "text": "その先輩の新美顔を吸収できるじゃないですか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 860.74,
    "end": 862.74,
    "text": "なので飲み会を無駄にするのか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 862.74,
    "end": 864.74,
    "text": "意味のあるものにするかっていうのも",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 864.74,
    "end": 866.74,
    "text": "飲み会に参加する人間の新美顔というか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 867.74,
    "end": 869.74,
    "text": "引き出すセンスによると思うので",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 869.74,
    "end": 871.74,
    "text": "陽君めちゃくちゃ後輩力あって",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 871.74,
    "end": 873.74,
    "text": "質問力のセンスめちゃくちゃいいんですよ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 873.74,
    "end": 875.74,
    "text": "飲み力ですかそれは",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 875.74,
    "end": 877.74,
    "text": "僕思うんですけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 877.74,
    "end": 879.74,
    "text": "結局どれを選んでもいいと思うんですよ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 879.74,
    "end": 880.74,
    "text": "投資になるじゃないですか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 880.74,
    "end": 882.74,
    "text": "それって投資にできるかどうかって",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 882.74,
    "end": 884.74,
    "text": "自分が気づくか気づかないかの話であって",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 884.74,
    "end": 886.74,
    "text": "資産価値全然考えなくても",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 886.74,
    "end": 888.74,
    "text": "ファッションめっちゃバーってやることによって",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 888.74,
    "end": 890.74,
    "text": "そういう新美顔が身につくパターンもあれば",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 890.74,
    "end": 892.74,
    "text": "いろんな人と行くことによって",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 892.74,
    "end": 895.74,
    "text": "そういう能力が身につけばそれも投資であるし",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 895.74,
    "end": 897.74,
    "text": "そのヴィンテージバーってやっても",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 897.74,
    "end": 899.74,
    "text": "そういう何かを作るときにデザイン性を加味して",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 899.74,
    "end": 901.74,
    "text": "考えるようになることができるっていうのも",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 901.74,
    "end": 903.74,
    "text": "一個投資じゃないですか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 903.74,
    "end": 905.74,
    "text": "だから結局どれ選んでもいいんだけど",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 905.74,
    "end": 908.74,
    "text": "選んだものをちゃんと自分の中で落とし込めるように",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 908.74,
    "end": 910.74,
    "text": "気づく力がないと",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 910.74,
    "end": 913.74,
    "text": "意味ない投資になっちゃうよね全てっていうのが",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 913.74,
    "end": 915.74,
    "text": "なんか今回の話を聞いて",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 915.74,
    "end": 917.74,
    "text": "いやもうそれだ",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 917.74,
    "end": 920.74,
    "text": "それ分かりやすく英語で言うと",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 920.74,
    "end": 922.74,
    "text": "それ分かりやすく英語で言うと",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 922.74,
    "end": 924.74,
    "text": "ちょっと一旦翻訳していいですか",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 924.74,
    "end": 926.74,
    "text": "そうですよね",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 926.74,
    "end": 927.74,
    "text": "いやいやでも",
    "source_file": "#19_fix.mp4"
  },
  {
    "start": 927.74,
    "end": 929.74,
    "text": "でも本当1週目2週目と",
